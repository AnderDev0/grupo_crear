---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ContactDialog from '../../components/ContactDialog.astro';
import RocketCursor from '../../components/RocketCursor.astro';
import EntregablesSection from '../../components/EntregablesSection.astro';
import { servicios } from '../../data/servicios';
import type { Servicio, Foto } from '../../data/servicios';

export function getStaticPaths() {
  return servicios.map(s => ({
    params: { slug: s.slug },
    props:  { servicio: s },
  }));
}

const { servicio: s } = Astro.props as { servicio: Servicio };

const otros    = servicios.filter(x => x.slug !== s.slug);
const hayFotos = s.fotos.length > 0;
// ── Film strips para galería de sub-página ────────────────────────────────
// Misma lógica que index.astro: shuffle + split no superpuesto.
// Cada foto aparece en UNA sola columna → imposible verla duplicada.

function seededShuffle<T>(arr: T[], seed: number): T[] {
  const copy = [...arr];
  let state = (seed * 1664525 + 1013904223) >>> 0;
  const rnd = () => {
    state = (state * 1664525 + 1013904223) >>> 0;
    return state / 0x100000000;
  };
  for (let i = copy.length - 1; i > 0; i--) {
    const j = Math.floor(rnd() * (i + 1));
    [copy[i], copy[j]] = [copy[j], copy[i]];
  }
  return copy;
}

const SUB_COLS    = 4;
const subSpeeds   = [230, 290, 195, 260] as const;
const subDelays   = [0, -95, -45, -165]  as const;

const subShuffled = seededShuffle(s.fotos as Foto[], 42);
const subChunk    = Math.ceil(subShuffled.length / SUB_COLS);
const subColFotos = Array.from({ length: SUB_COLS }, (_, ci) =>
  subShuffled.slice(ci * subChunk, Math.min((ci + 1) * subChunk, subShuffled.length))
);

const pasos = s.pasos;
---

<Layout
  title={`${s.nombre} — Grupo Crear · Bogotá`}
  description={s.descripcionLarga}
>
  <RocketCursor slot="cursor" />

  <!-- ═══════════════════════════════════════
       STICKY NAV DE SERVICIOS
  ═══════════════════════════════════════ -->
  <div id="serv-nav" aria-label="Navegar entre servicios">
    <div class="sn-inner">
      {servicios.map((item) => (
        <a
          href={`/servicios/${item.slug}`}
          class={`sn-pill${item.slug === s.slug ? ' active' : ''}`}
          data-slug={item.slug}
        >
          {item.nombreCorto}
        </a>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       BREADCRUMB + MINI HERO
  ═══════════════════════════════════════ -->
  <section id="sub-hero" class="sub-section" aria-labelledby="sub-h1">
    <!-- Glow -->
    <div class="sh-glow" aria-hidden="true"></div>

    <!-- Breadcrumb -->
    <div class="wrap">
      <nav class="breadcrumb" aria-label="Ubicación">
        <a href="/">Inicio</a>
        <span aria-hidden="true">→</span>
        <a href="/servicios">Servicios</a>
        <span aria-hidden="true">→</span>
        <span aria-current="page">{s.nombre}</span>
      </nav>

      <div class="sub-grid">
        <!-- Texto -->
        <div class="sub-txt">
          <div class="idx">{s.numero} — {s.nombreCorto}</div>
          <h1 class="lead sub-h1" id="sub-h1">
            <span class="ln"><span>{s.nombre.split(' ').slice(0,-1).join(' ')}</span></span>
            <span class="ln"><span><em>{s.nombre.split(' ').slice(-1)[0]}.</em></span></span>
          </h1>
          <p class="sub-desc" id="sub-desc">{s.descripcionLarga}</p>
          <div class="sub-acts" id="sub-acts">
            <a
              href={`https://wa.me/573000000000?text=${s.whatsappText}`}
              class="btn-fill"
              target="_blank"
              rel="noopener noreferrer"
            >
              Pedir cotización
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6"/>
              </svg>
            </a>
            <button class="btn-line" id="openContactSub">Más información</button>
          </div>
        </div>

        <!-- Imagen destacada -->
        <div class="sub-img-wrap" id="sub-img-wrap">
          <div
            class="sub-frame"
            style={s.fotoPrincipal
              ? `background-image:url(${s.fotoPrincipal})`
              : `background:${s.gradiente}`}
            aria-hidden="true"
          >
            {s.fotoPrincipal && (
              <img
                src={s.fotoPrincipal}
                alt=""
                loading="eager"
                draggable="false"
              />
            )}
            <div class="sub-frame-overlay"></div>
            <div class="sub-protect"></div>
          </div>
          <div class="sub-badge">
            <b>+500</b>
            <small>proyectos de {s.nombreCorto}</small>
          </div>
        </div>
      </div>
    </div>
  </section>

  <EntregablesSection entregables={s.entregables} />

  <!-- ═══════════════════════════════════════
       PROCESO DE TRABAJO
  ═══════════════════════════════════════ -->
  <section id="proceso" aria-labelledby="proc-title" class="sub-section">
    <div class="wrap">
      <div class="idx r">Metodología</div>
      <h2 class="lead r" data-d="1" id="proc-title">Cómo <em>trabajamos.</em></h2>
      <div class="proc-track">
        {pasos.map((p, i) => (
          <div class="paso r" data-d={String(i + 1)}>
            <div class="paso-num">{p.num}</div>
            <div class="paso-body">
              <h3 class="paso-title">{p.titulo}</h3>
              <p class="paso-desc">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       GALERÍA DEL SERVICIO
  ═══════════════════════════════════════ -->
  <section id="galeria-serv" aria-labelledby="gal-serv-title" class="sub-section-alt">
    <div class="wrap">
      <div class="idx r">Trabajos realizados</div>
      <h2 class="lead r" data-d="1" id="gal-serv-title">Proyectos de <em>{s.nombreCorto}.</em></h2>

      {hayFotos ? (
        <div class="gal-sub-strip" id="galSubStrip">
          {subColFotos.map((colFotos, ci) => colFotos.length > 0 && (
            <div
              class={`gal-sub-col gal-sub-${ci % 2 === 0 ? 'up' : 'down'}`}
              style={`--spd:${subSpeeds[ci]}s; --dly:${subDelays[ci]}s`}
            >
              <div class="gal-sub-track">
                {/* Set A — ítems reales */}
                {colFotos.map((foto: Foto) => (
                  <div class="gal-item-sub">
                    <div class="gal-protect" aria-hidden="true"></div>
                    <img src={foto.src} alt={foto.alt} loading="lazy" draggable="false" />
                  </div>
                ))}
                {/* Set B — duplicado para loop sin costura */}
                {colFotos.map((foto: Foto) => (
                  <div class="gal-item-sub" aria-hidden="true">
                    <div class="gal-protect" aria-hidden="true"></div>
                    <img src={foto.src} alt="" loading="lazy" draggable="false" />
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="gal-empty r" data-d="2">
          <p>Las fotos de {s.nombreCorto} se cargarán próximamente.</p>
          <span>Agrega las rutas en el campo <code>fotos[]</code> del servicio <code>{s.slug}</code></span>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       OTROS SERVICIOS
  ═══════════════════════════════════════ -->
  <section id="otros-serv" aria-labelledby="otros-title" class="sub-section">
    <div class="wrap">
      <div class="serv-head">
        <div>
          <div class="idx r">Más servicios</div>
          <h2 class="lead r" data-d="1" id="otros-title">También <em>hacemos.</em></h2>
        </div>
        <a href="/servicios" class="btn-line r" data-d="2">Ver todos →</a>
      </div>
      <div class="otros-grid">
        {otros.map((o, i) => (
          <a
            href={`/servicios/${o.slug}`}
            class="otro-card r"
            data-d={String((i % 3) + 1)}
            aria-label={o.nombre}
          >
            <div
              class="oc-img"
              style={o.fotoPrincipal
                ? `background-image:url(${o.fotoPrincipal})`
                : `background:${o.gradiente}`}
              aria-hidden="true"
            ></div>
            <div class="oc-overlay" aria-hidden="true"></div>
            <div class="oc-body">
              <span class="oc-num">{o.numero}</span>
              <h3 class="oc-title">{o.nombreCorto}</h3>
            </div>
            <div class="oc-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                <path d="M7 17L17 7M17 7H8M17 7v9"/>
              </svg>
            </div>
            <div class="oc-protect"></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CTA FINAL
  ═══════════════════════════════════════ -->
  <!-- ═══════════════════════════════════════
       CTA DOBLE
  ═══════════════════════════════════════ -->
  <section class="cto-serv-section" aria-labelledby="cto-title">
    <div class="cto-huge" aria-hidden="true">Crear</div>
    <div class="wrap">
      <div class="cto-container">

        <!-- Columna 1: WhatsApp -->
        <div class="cto-card r" data-d="1">
          <div class="cto-card-glow" aria-hidden="true"></div>
          <div class="cto-card-header">
            <div class="cto-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 21l1.6-4A8.5 8.5 0 1 1 8 19.4z"/>
                <path d="M9 10c0 3 2 5 5 5"/>
              </svg>
            </div>
            <span class="cto-card-kicker">Respuesta inmediata</span>
          </div>
          <h2 id="cto-title" class="cto-card-title">Respuesta rápida</h2>
          <p class="cto-card-desc">Cuéntanos qué necesitas. Respondemos en menos de 24 horas con una propuesta concreta y sin compromiso.</p>
          <a
            href={`https://wa.me/573000000000?text=${s.whatsappText}`}
            class="btn-fill cto-card-btn"
            target="_blank"
            rel="noopener noreferrer"
          >
            Escribir por WhatsApp
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
        </div>

        <!-- Columna 2: Cotización Formal -->
        <div class="cto-card r" data-d="2">
          <div class="cto-card-glow" aria-hidden="true"></div>
          <div class="cto-card-header">
            <div class="cto-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="5" width="18" height="14" rx="2"/>
                <path d="M3 7l9 6 9-6"/>
              </svg>
            </div>
            <span class="cto-card-kicker">Propuesta formal</span>
          </div>
          <h3 class="cto-card-title">Cotización formal</h3>
          <p class="cto-card-desc">Prefiere un presupuesto detallado por escrito. Llena el formulario y te respondemos con una cotización estructurada.</p>
          <button class="btn-outline cto-card-btn" id="openContactSub2">
            Pedir cotización
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </button>
        </div>

      </div>
    </div>
  </section>

  <Footer />
  <ContactDialog />
</Layout>

<style>
/* ── LAYOUT BASE DE SUB-PÁGINAS ── */
.sub-section     { background: var(--bg); }
.sub-section-alt { background: var(--ink); }

/* ── BREADCRUMB ── */
.breadcrumb {
  display: flex; align-items: center; gap: 10px;
  font-size: 13px; color: var(--w40);
  margin-bottom: clamp(32px,5vw,56px);
}
.breadcrumb a { color: var(--w60); text-decoration: none; transition: color .3s; }
.breadcrumb a:hover { color: var(--n); }

/* ── MINI HERO ── */
#sub-hero {
  position: relative;
  overflow: hidden;
  /* El nav es fixed (84px top) y no empuja el contenido.
     Este padding-top suma la altura del nav + espacio editorial. */
  padding-top: calc(84px + clamp(40px, 6vw, 72px)) !important;
}
.sh-glow {
  position: absolute; pointer-events: none;
  width: 60vw; height: 60vw; max-width: 800px; max-height: 800px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,78,27,.18), transparent 60%);
  top: -20%; right: -10%; filter: blur(40px);
  animation: sh-breathe 9s ease-in-out infinite alternate;
}
@keyframes sh-breathe {
  from { transform: scale(.9); opacity: .7; }
  to   { transform: scale(1.08); opacity: 1; }
}

.sub-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(40px,6vw,80px);
  align-items: center;
}
.sub-h1 { margin: clamp(16px,2.5vw,28px) 0; }
.sub-h1 .ln { display: block; overflow: hidden; }
.sub-h1 .ln span { display: block; }

.sub-desc {
  font-size: clamp(15px,1.4vw,18px);
  color: var(--w60); line-height: 1.7;
  max-width: 480px; margin-bottom: clamp(24px,3.5vw,40px);
}
.sub-acts { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; }

.sub-img-wrap { position: relative; }
.sub-frame {
  position: relative;
  border-radius: 10px; overflow: hidden;
  aspect-ratio: 4/3;
  background-size: cover; background-position: center;
}
.sub-frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
.sub-frame-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,20,60,.3), transparent 60%);
}
.sub-protect { position: absolute; inset: 0; z-index: 2; }
.sub-badge {
  position: absolute; bottom: -20px; left: -20px;
  background: var(--n); color: #fff;
  border-radius: 8px; padding: 18px 22px;
}
.sub-badge b { font-family: 'Sofia Sans Condensed',sans-serif; font-size: 42px; font-weight: 900; line-height: .85; display: block; }
.sub-badge small { display: block; margin-top: 6px; font-size: 13px; opacity: .9; }

@media (max-width: 768px) {
  .sub-grid { grid-template-columns: 1fr; }
  .sub-badge { left: 0; }
}

/* ── PROCESO ── */
.proc-track {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  position: relative;
  margin-top: clamp(36px,5vw,56px);
}
.proc-track::before {
  content: "";
  position: absolute; top: 28px; left: 10%; right: 10%; height: 1px;
  background: linear-gradient(90deg, var(--n), rgba(232,78,27,.1));
}
.paso { padding: 0 clamp(12px,2vw,24px); }
.paso-num {
  width: 56px; height: 56px; border-radius: 50%;
  background: var(--n); color: #fff;
  font-family: 'Sofia Sans Condensed',sans-serif;
  font-size: 22px; font-weight: 900;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 20px; position: relative; z-index: 1;
}
.paso-title {
  font-family: 'Sofia Sans Condensed',sans-serif;
  font-size: 22px; font-weight: 800; text-transform: uppercase;
  margin-bottom: 8px;
}
.paso-desc { font-size: 14px; color: var(--w60); line-height: 1.6; }

@media (max-width: 768px) {
  .proc-track { grid-template-columns: 1fr; gap: 28px; }
  .proc-track::before { top: 28px; bottom: 28px; left: 28px; right: auto; width: 1px; height: auto; }
  .paso { display: grid; grid-template-columns: 56px 1fr; gap: 16px; align-items: start; }
  .paso-num { margin-bottom: 0; }
}

/* ── GALERÍA SUB — Film Strips ── */
#galeria-serv { padding-left: 0; padding-right: 0; }

.gal-sub-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: clamp(8px, 1vw, 12px);
  height: 82vh;
  min-height: 500px;
  overflow: hidden;
  margin-top: clamp(28px,4vw,48px);
  mask-image: linear-gradient(to bottom, transparent 0%, #000 7%, #000 93%, transparent 100%);
  -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 7%, #000 93%, transparent 100%);
}

.gal-sub-col   { overflow: hidden; position: relative; }
.gal-sub-track {
  display: flex; flex-direction: column;
  gap: clamp(8px, 1vw, 12px);
  will-change: transform;
}

.gal-sub-up .gal-sub-track {
  animation: strip-up var(--spd, 230s) linear infinite;
  animation-delay: var(--dly, 0s);
}
.gal-sub-down .gal-sub-track {
  animation: strip-down var(--spd, 260s) linear infinite;
  animation-delay: var(--dly, 0s);
}
.gal-sub-col:hover .gal-sub-track { animation-play-state: paused; }

@keyframes strip-up   { from { transform:translateY(0) } to { transform:translateY(-50%) } }
@keyframes strip-down { from { transform:translateY(-50%) } to { transform:translateY(0) } }

.gal-item-sub {
  position: relative; border-radius: 8px; overflow: hidden; flex-shrink: 0;
}
.gal-item-sub img {
  width: 100%; display: block; object-fit: cover;
  pointer-events: none; -webkit-user-drag: none;
  transition: transform .9s var(--ease);
}
/* Mismo patrón de 7 alturas que la galería overview — referencia masonry variado */
.gal-item-sub:nth-child(7n+1) img { height: clamp(195px,18vw,270px); }  /* paisaje 4:3 */
.gal-item-sub:nth-child(7n+2) img { height: clamp(340px,32vw,440px); }  /* retrato alto 2:3 */
.gal-item-sub:nth-child(7n+3) img { height: clamp(145px,13vw,195px); }  /* panorámico 16:9 */
.gal-item-sub:nth-child(7n+4) img { height: clamp(265px,25vw,355px); }  /* retrato 3:4 */
.gal-item-sub:nth-child(7n+5) img { height: clamp(215px,20vw,285px); }  /* cuadrado aprox. */
.gal-item-sub:nth-child(7n+6) img { height: clamp(295px,28vw,395px); }  /* retrato muy alto */
.gal-item-sub:nth-child(7n+7) img { height: clamp(165px,15vw,225px); }  /* paisaje corto */
.gal-item-sub:hover img { transform: scale(1.04); }

.gal-protect { position: absolute; inset: 0; z-index: 2; }

/* Spotlight de cursor */
.gal-item-sub::after {
  content: ''; position: absolute; inset: 0; z-index: 3; pointer-events: none;
  opacity: 0; border-radius: inherit;
  background: radial-gradient(160px at var(--mx,50%) var(--my,50%),rgba(232,78,27,.12),transparent 70%);
  transition: opacity .3s;
}
.gal-item-sub:hover::after { opacity: 1; }

@media (max-width: 900px)  { .gal-sub-strip { grid-template-columns: repeat(3, 1fr); height: 70vh; } }
@media (max-width: 580px)  { .gal-sub-strip { grid-template-columns: repeat(2, 1fr); height: 60vh; } }

.gal-empty {
  margin-top: clamp(28px,4vw,48px);
  padding: clamp(40px,6vw,80px) 0;
  text-align: center;
  border: 1px dashed var(--w12); border-radius: 10px;
}
.gal-empty p { color: var(--w60); font-size: 16px; margin-bottom: 12px; }
.gal-empty span { font-size: 13px; color: var(--w40); }
.gal-empty code { color: var(--n); background: rgba(232,78,27,.08); border: 1px solid rgba(232,78,27,.2); padding: 2px 8px; border-radius: 4px; font-family: monospace; }

@media (max-width: 1024px) { .gal-grid-sub { columns: 3; } }
@media (max-width: 680px)  { .gal-grid-sub { columns: 2; } }

/* ── OTROS SERVICIOS ── */
.otros-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: clamp(10px,1.2vw,14px);
  margin-top: clamp(36px,5vw,56px);
}
.otro-card {
  position: relative;
  border-radius: 8px; overflow: hidden;
  min-height: 180px;
  text-decoration: none; cursor: none;
  border: 1px solid var(--w06);
  transition: border-color .4s var(--ease);
  display: flex; flex-direction: column; justify-content: flex-end;
}
.otro-card:hover { border-color: rgba(232,78,27,.35); }
.otro-card:hover .oc-img { transform: scale(1.06); }
.otro-card:hover .oc-arrow { opacity: 1; transform: none; }

.oc-img {
  position: absolute; inset: 0;
  background-position: center;
  background-size: cover;
  background-repeat: no-repeat;
  transition: transform .8s var(--ease);
}
.oc-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,12,36,.92) 0%, transparent 60%);
}
.oc-body { position: relative; z-index: 2; padding: 16px; }
.oc-num {
  display: block;
  font-family: 'Sofia Sans Condensed',sans-serif;
  font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--n); margin-bottom: 6px;
}
.oc-title {
  font-family: 'Sofia Sans Condensed',sans-serif;
  font-size: 18px; font-weight: 800; text-transform: uppercase;
  color: #fff; line-height: 1;
}
.oc-arrow {
  position: absolute; top: 14px; right: 14px; z-index: 2;
  width: 36px; height: 36px;
  border: 1px solid var(--w12); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transform: translate(-4px,4px);
  transition: .4s var(--ease);
}
.oc-arrow svg { width: 13px; height: 13px; stroke: #fff; }
.oc-protect { position: absolute; inset: 0; z-index: 1; }

@media (max-width: 1024px) { .otros-grid { grid-template-columns: repeat(3,1fr); } }
@media (max-width: 680px)  { .otros-grid { grid-template-columns: repeat(2,1fr); } }

/* ── CTA DOBLE ── */
.cto-serv-section {
  background: var(--ink);
  position: relative;
  overflow: hidden;
  padding: clamp(80px, 11vw, 150px) 0;
}
.cto-container {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(24px, 4vw, 48px);
}
.cto-card {
  position: relative;
  background: rgba(255, 255, 255, 0.02);
  backdrop-filter: blur(12px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 20px;
  padding: clamp(30px, 5vw, 56px);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  transition: border-color 0.4s var(--ease), background 0.4s var(--ease), transform 0.4s var(--ease);
  overflow: hidden;
}
.cto-card:hover {
  border-color: rgba(232, 78, 27, 0.35);
  background: rgba(255, 255, 255, 0.03);
  transform: translateY(-4px);
}
.cto-card-glow {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(
    300px circle at var(--mx, 50%) var(--my, 50%),
    rgba(232, 78, 27, 0.08),
    transparent 65%
  );
  opacity: 0;
  transition: opacity 0.4s var(--ease);
  z-index: 0;
}
.cto-card:hover .cto-card-glow {
  opacity: 1;
}
.cto-card-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 24px;
  position: relative;
  z-index: 1;
}
.cto-card-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: rgba(232, 78, 27, 0.08);
  border: 1px solid rgba(232, 78, 27, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--n);
  transition: transform 0.4s var(--ease), background 0.4s var(--ease);
}
.cto-card:hover .cto-card-icon {
  transform: scale(1.1) rotate(5deg);
  background: rgba(232, 78, 27, 0.15);
}
.cto-card-icon svg {
  width: 24px;
  height: 24px;
}
.cto-card-kicker {
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--w40);
}
.cto-card-title {
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: clamp(24px, 3vw, 42px);
  font-weight: 900;
  text-transform: uppercase;
  color: #fff;
  margin: 0 0 16px 0;
  line-height: 1;
  letter-spacing: -0.02em;
  position: relative;
  z-index: 1;
}
.cto-card-desc {
  font-size: clamp(14px, 1.2vw, 16px);
  color: var(--w60);
  line-height: 1.65;
  margin: 0 0 36px 0;
  max-width: 480px;
  flex-grow: 1;
  position: relative;
  z-index: 1;
}
.cto-card-btn {
  position: relative;
  z-index: 1;
}
.btn-outline {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: transparent;
  color: #fff;
  text-decoration: none;
  padding: 17px 30px;
  border-radius: 100px;
  font-weight: 600;
  font-size: 15px;
  border: 1px solid rgba(255, 255, 255, 0.15);
  font-family: 'Sofia Sans', sans-serif;
  cursor: none;
  transition: background 0.3s, border-color 0.3s, color 0.3s;
}
.btn-outline:hover {
  background: #fff;
  border-color: #fff;
  color: var(--ink);
}
.btn-outline svg {
  width: 16px;
  height: 16px;
  transition: transform 0.3s;
}
.btn-outline:hover svg {
  transform: translateX(4px);
  stroke: var(--ink);
}
@media (max-width: 860px) {
  .cto-container {
    grid-template-columns: 1fr;
    gap: 24px;
  }
}

/* ── STICKY NAV (CÁPSULA FLOTANTE PREMIUM) ── */
#serv-nav {
  position: sticky;
  top: 92px; /* Mayor espacio (28px) por debajo del navbar colapsado de 64px para dar aire visual */
  z-index: 200;
  width: max-content;
  max-width: calc(100vw - 40px);
  margin: 24px auto;
  background: rgba(0, 16, 42, 0.78);
  backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 100px;
  padding: 6px;
  box-shadow: 
    0 16px 36px rgba(0, 0, 0, 0.5), 
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
  /* Oculto por defecto */
  opacity: 0;
  visibility: hidden;
  transform: translateY(-10px) scale(0.95);
  transition: 
    opacity 0.4s var(--ease), 
    visibility 0.4s var(--ease), 
    transform 0.4s var(--ease);
}
#serv-nav.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0) scale(1);
}
.sn-inner {
  display: flex;
  gap: 4px;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}
.sn-inner::-webkit-scrollbar { display: none; }

.sn-pill {
  flex-shrink: 0;
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--w60);
  border: 1px solid transparent;
  border-radius: 100px;
  padding: 7px 16px;
  background: transparent;
  cursor: none;
  transition: .3s var(--ease);
  white-space: nowrap;
}
.sn-pill:hover { 
  color: #fff; 
  background: var(--n); 
  border-color: var(--n); 
}
.sn-pill.active { 
  color: var(--n); 
  font-weight: 700;
}
</style>

<script>
  import { gsap, ScrollTrigger } from '../../utils/gsap-config';

  const prefersRM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── STICKY NAV REVEAL ON SCROLL ── */
  ScrollTrigger.create({
    trigger: '#sub-hero',
    start: 'bottom top+=92',
    onEnter: () => document.getElementById('serv-nav')?.classList.add('visible'),
    onLeaveBack: () => document.getElementById('serv-nav')?.classList.remove('visible'),
    onRefresh: (self) => {
      const nav = document.getElementById('serv-nav');
      if (self.progress > 0) {
        nav?.classList.add('visible');
      } else {
        nav?.classList.remove('visible');
      }
    }
  });

  /* ── HERO ENTRANCE ── */
  if (!prefersRM) {
    // Seteamos el estado inicial en JS de inmediato
    gsap.set('.sub-txt .idx', { opacity: 0, y: 16 });
    gsap.set('.sub-desc',     { opacity: 0, y: 20 });
    gsap.set('.sub-acts',     { opacity: 0, y: 16 });
    gsap.set('.sub-img-wrap', { opacity: 0, x: 30 });

    gsap.timeline({ defaults: { ease: 'power4.out' } })
      .to('.sub-txt .idx',     { opacity: 1, y: 0, duration: .6 }, .15)
      .from('.sub-h1 .ln span',  { y: '105%', stagger: .12, duration: .9 }, .25)
      .to('.sub-desc',         { opacity: 1, y: 0, duration: .7 }, '-=.5')
      .to('.sub-acts',         { opacity: 1, y: 0, duration: .6 }, '-=.4')
      .to('.sub-img-wrap',     { opacity: 1, x: 0, duration: .9 }, .3);
  }

  /* ── PROCESO — ANIMACIÓN SECUENCIAL ── */
  if (!prefersRM) {
    gsap.from('.paso', {
      opacity: 0, y: 30,
      stagger: .15, duration: .8, ease: 'power3.out',
      scrollTrigger: { trigger: '#proceso', start: 'top 75%' },
    });
  }

  /* ── GALERÍA SUB — Strips usan CSS animation; solo spotlight de cursor ── */
  document.querySelectorAll<HTMLElement>('.gal-item-sub').forEach(item => {
    item.addEventListener('mousemove', (e: MouseEvent) => {
      const r = item.getBoundingClientRect();
      item.style.setProperty('--mx', `${((e.clientX - r.left) / r.width  * 100).toFixed(1)}%`);
      item.style.setProperty('--my', `${((e.clientY - r.top)  / r.height * 100).toFixed(1)}%`);
    });
  });

  /* ── PROTECCIÓN DE IMÁGENES ── */
  ['#galeria-serv','#otros-serv','#sub-hero'].forEach(sel => {
    document.querySelector(sel)?.addEventListener('contextmenu', e => e.preventDefault());
    document.querySelector(sel)?.addEventListener('dragstart',   e => e.preventDefault());
  });

  /* ── CTAs → ContactDialog ── */
  const openDialog = () => {
    document.querySelector<HTMLDialogElement>('#contact-dialog')?.showModal();
  };
  document.getElementById('openContactSub')?.addEventListener('click', openDialog);
  document.getElementById('openContactSub2')?.addEventListener('click', openDialog);

  /* ── CTA CARDS — SPOTLIGHT DE CURSOR ───────────────── */
  document.querySelectorAll<HTMLElement>('.cto-card').forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const r = card.getBoundingClientRect();
      card.style.setProperty('--mx', `${e.clientX - r.left}px`);
      card.style.setProperty('--my', `${e.clientY - r.top}px`);
    });
  });
</script>
