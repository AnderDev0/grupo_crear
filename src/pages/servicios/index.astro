---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ContactDialog from '../../components/ContactDialog.astro';
import RocketCursor from '../../components/RocketCursor.astro';
import { servicios } from '../../data/servicios';

// Fotos para la galería: aplana todos los arrays fotos[] de cada servicio
const todasFotos = servicios.flatMap(s =>
  s.fotos.map(f => ({ src: f.src, alt: f.alt, slug: s.slug, cat: s.nombreCorto }))
);
const hayFotos = todasFotos.length > 0;

// ── Film strips ────────────────────────────────────────────────────────────
// 5 columnas en "Todos", 4 cuando hay filtro activo.
// Cada columna tiene su propio shuffle deterministico para que el orden de
// fotos sea completamente diferente entre columnas (no solo desplazado).
// Los delays negativos hacen que cada tira arranque en un punto distinto
// de su ciclo → nunca parecen sincronizadas entre sí.

// Shuffle LCG deterministico — mismo resultado en cada build (SSG)
type Foto = { src: string; alt: string; slug: string; cat: string };
function seededShuffle(arr: Foto[], seed: number): Foto[] {
  const copy = [...arr];
  let s = (seed * 1664525 + 1013904223) >>> 0;
  const rnd = () => { s = (s * 1664525 + 1013904223) >>> 0; return s / 0x100000000; };
  for (let i = copy.length - 1; i > 0; i--) {
    const j = Math.floor(rnd() * (i + 1));
    [copy[i], copy[j]] = [copy[j], copy[i]];
  }
  return copy;
}

const STRIP_COLS  = 5;
const stripSpeeds = [240, 300, 200, 270, 220] as const;
const stripDelays = [0, -110, -55, -185, -80] as const;

// DISTRIBUCIÓN NO SUPERPUESTA:
// 1. shuffle global de todas las fotos
// 2. split en 5 chunks sin solapamiento → cada foto va a UNA SOLA columna
// Así nunca puede aparecer la misma foto en dos columnas a la vez.
const allShuffled  = seededShuffle(todasFotos, 42);
const chunkSize    = Math.ceil(allShuffled.length / STRIP_COLS);
const stripColFotos = Array.from({ length: STRIP_COLS }, (_, ci) =>
  allShuffled.slice(ci * chunkSize, Math.min((ci + 1) * chunkSize, allShuffled.length))
);
---

<Layout
  title="Servicios — Grupo Crear · Agencia de Publicidad Bogotá"
  description="Impresión gran formato, material POP, branding, fotografía, diseño web y campañas integrales. Soluciones gráficas completas en Bogotá, Colombia."
>
  <RocketCursor slot="cursor" />

  <!-- ═══════════════════════════════════════
       HERO EDITORIAL
  ═══════════════════════════════════════ -->
  <section id="serv-hero" aria-label="Servicios Grupo Crear">
    <!-- Glow atmosférico naranja -->
    <div class="sh-glow" aria-hidden="true"></div>
    <!-- Watermark fantasma -->
    <div class="sh-ghost" aria-hidden="true">SERVICIOS</div>

    <div class="wrap sh-grid">
      <!-- Columna texto -->
      <div class="sh-txt">
        <div class="idx" id="sh-idx">00 — Servicios</div>

        <h1 class="lead sh-h1" id="sh-h1" aria-label="Seis disciplinas. Una sola dirección.">
          <span class="ln"><span>Seis disciplinas.</span></span>
          <span class="ln"><span>Una sola <em>dirección.</em></span></span>
        </h1>

        <p class="sh-sub" id="sh-sub">
          Del concepto a la producción — diseño, impresión,<br aria-hidden="true">
          branding y digital bajo un mismo equipo creativo.
        </p>

        <!-- Pills de servicios (accesos rápidos) -->
        <div class="sh-pills" id="sh-pills">
          {servicios.map(s => (
            <a
              href={`/servicios/${s.slug}`}
              class="sh-pill"
              aria-label={`Ir a ${s.nombre}`}
            >
              {s.nombreCorto}
            </a>
          ))}
        </div>
      </div>

      <!-- Collage flotante -->
      <div class="sh-collage" aria-hidden="true">
        <div class="hc hc-1">
          <img src="/rebranding_nexus.webp" alt="" draggable="false" loading="eager" />
        </div>
        <div class="hc hc-2">
          <img src="/alternativa_naranja3d.webp" alt="" draggable="false" loading="eager" />
        </div>
        <div class="hc hc-3">
          <!-- Video circular pequeño -->
          <video autoplay loop muted playsinline>
            <source src="/Impresion-a-gran-formato_naranja_3.webm" type="video/webm" />
          </video>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       STICKY NAV DE SERVICIOS
  ═══════════════════════════════════════ -->
  <div id="serv-nav" aria-label="Navegar entre servicios">
    <div class="sn-inner">
      {servicios.map((s) => (
        <a
          href={`/servicios/${s.slug}`}
          class="sn-pill"
        >
          {s.nombreCorto}
        </a>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       BENTO GRID
  ═══════════════════════════════════════ -->
  <section id="serv-bento" aria-labelledby="bento-title">
    <div class="wrap">
      <div class="serv-head">
        <div>
          <div class="idx r">01 — Nuestros servicios</div>
          <h2 class="lead r" data-d="1" id="bento-title">Lo que <em>hacemos.</em></h2>
        </div>
        <p class="r" data-d="2">
          Seis especialidades integradas bajo una sola dirección creativa — lo que
          se imprime, lo que se publica y lo que se ve en el punto de venta hablan
          el mismo idioma.
        </p>
      </div>

      <div class="bento-grid">
        {servicios.map((s, i) => (
          <a
            id={`serv-${s.slug}`}
            href={`/servicios/${s.slug}`}
            class={`bc r bc-${String(i + 1).padStart(2, '0')}`}
            data-d={String((i % 3) + 1)}
            aria-label={s.nombre}
          >
            {/* Fondo */}
            <div
              class="bc-img"
              style={s.fotoPrincipal
                ? `background-image:url(${s.fotoPrincipal})`
                : `background:${s.gradiente}`}
              aria-hidden="true"
            ></div>
            <div class="bc-overlay" aria-hidden="true"></div>

            {/* Número fantasma */}
            <span class="bc-num" aria-hidden="true">{s.numero}</span>

            {/* Contenido */}
            <div class="bc-body">
              <div class="bc-chips">
                {s.chips.map(c => <span class="bc-chip">{c}</span>)}
              </div>
              <h3 class="bc-title">{s.nombre}</h3>
              <p class="bc-desc">{s.descripcionCorta}</p>
            </div>

            {/* Flecha hover */}
            <div class="bc-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                <path d="M7 17L17 7M17 7H8M17 7v9"/>
              </svg>
            </div>

            {/* Protección de imagen */}
            <div class="bc-protect"></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       GALERÍA FILTRABLE
  ═══════════════════════════════════════ -->
  <section id="galeria" aria-labelledby="gal-title">
    <div class="wrap">
      <div class="gal-header">
        <div class="idx r">02 — Portafolio</div>
        <h2 class="lead r" data-d="1" id="gal-title">El trabajo <em>habla solo.</em></h2>
        <p class="r" data-d="2">
          Más de 100 proyectos entregados. Filtra por categoría.
        </p>

        <!-- Filtros -->
        <div class="gal-filters r" data-d="3" role="group" aria-label="Filtrar por categoría">
          <button class="gal-pill active" data-filter="*">Todos</button>
          {servicios.map(s => {
            const tieneFotos = s.fotos && s.fotos.length > 0;
            if (!tieneFotos) return null;
            return <button class="gal-pill" data-filter={s.slug}>{s.nombreCorto}</button>;
          })}
        </div>
      </div>

      {hayFotos ? (
        /* ── Film Strips: columnas que se mueven en direcciones alternas ── */
        <div class="gal-strip" id="galStrip">
          {stripColFotos.map((colFotos, ci) => colFotos.length > 0 && (
            <div
              class={`gal-col gal-col-${ci % 2 === 0 ? 'up' : 'down'}`}
              style={`--spd:${stripSpeeds[ci]}s; --dly:${stripDelays[ci]}s`}
            >
              <div class="gal-track">
                {/* Set A — ítems reales */}
                {colFotos.map(f => (
                  <div class="gal-si" data-cat={f.slug}>
                    <div class="gal-protect" aria-hidden="true"></div>
                    <img src={f.src} alt={f.alt} loading="lazy" draggable="false" />
                    <span class="gal-badge">{f.cat}</span>
                  </div>
                ))}
                {/* Set B — duplicado para loop sin costura */}
                {colFotos.map(f => (
                  <div class="gal-si" data-cat={f.slug} aria-hidden="true">
                    <div class="gal-protect" aria-hidden="true"></div>
                    <img src={f.src} alt="" loading="lazy" draggable="false" />
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="gal-empty r" data-d="2">
          <p>El portafolio fotográfico se cargará próximamente.</p>
          <span>Agrega las rutas en <code>src/data/servicios.ts</code> → campo <code>fotos[]</code></span>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CTA DOBLE
  ═══════════════════════════════════════ -->
  <section class="cto-serv-section" aria-labelledby="cto-title">
    <div class="cto-huge" aria-hidden="true">Crear</div>
    <div class="wrap">
      <div class="cto-container">

        <!-- Columna 1: WhatsApp -->
        <div class="cto-card r" data-d="1">
          <div class="cto-card-glow" aria-hidden="true"></div>
          <div class="cto-card-header">
            <div class="cto-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 21l1.6-4A8.5 8.5 0 1 1 8 19.4z"/>
                <path d="M9 10c0 3 2 5 5 5"/>
              </svg>
            </div>
            <span class="cto-card-kicker">Respuesta inmediata</span>
          </div>
          <h2 id="cto-title" class="cto-card-title">Respuesta rápida</h2>
          <p class="cto-card-desc">Cuéntanos qué necesitas. Respondemos en menos de 24 horas con una propuesta concreta y sin compromiso.</p>
          <a
            href="https://wa.me/573000000000"
            class="btn-fill cto-card-btn"
            target="_blank"
            rel="noopener noreferrer"
          >
            Escribir por WhatsApp
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
        </div>

        <!-- Columna 2: Cotización Formal -->
        <div class="cto-card r" data-d="2">
          <div class="cto-card-glow" aria-hidden="true"></div>
          <div class="cto-card-header">
            <div class="cto-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="5" width="18" height="14" rx="2"/>
                <path d="M3 7l9 6 9-6"/>
              </svg>
            </div>
            <span class="cto-card-kicker">Propuesta formal</span>
          </div>
          <h3 class="cto-card-title">Cotización formal</h3>
          <p class="cto-card-desc">Prefiere un presupuesto detallado por escrito. Llena el formulario y te respondemos con una cotización estructurada.</p>
          <button class="btn-outline cto-card-btn" id="openContactServ">
            Pedir cotización
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </button>
        </div>

      </div>
    </div>
  </section>

  <Footer />
  <ContactDialog />
</Layout>

<!-- ═══════════════════════════════════════════════════════════
     ESTILOS
════════════════════════════════════════════════════════════ -->
<style>
/* ── HERO ── */
#serv-hero {
  position: relative;
  min-height: 72vh;
  display: flex;
  align-items: center;
  padding: calc(84px + clamp(60px,8vw,100px)) clamp(20px,5vw,64px) clamp(60px,8vw,100px);
  overflow: hidden;
  background: var(--bg);
}

.sh-glow {
  position: absolute;
  width: 70vw; height: 70vw;
  max-width: 900px; max-height: 900px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,78,27,.2), transparent 60%);
  top: -25%; right: -15%;
  filter: blur(40px);
  pointer-events: none;
  animation: sh-breathe 9s ease-in-out infinite alternate;
}
@keyframes sh-breathe {
  from { transform: scale(.9); opacity: .7; }
  to   { transform: scale(1.08); opacity: 1; }
}

.sh-ghost {
  position: absolute;
  left: clamp(20px,5vw,64px);
  top: 50%; transform: translateY(-50%);
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(130px,20vw,320px);
  line-height: .8;
  color: transparent;
  -webkit-text-stroke: 1px rgba(255,255,255,.04);
  letter-spacing: -.04em;
  text-transform: uppercase;
  pointer-events: none;
  user-select: none;
  white-space: nowrap;
}

.sh-grid {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(40px,6vw,80px);
  align-items: center;
}

/* Texto */
.sh-h1 { margin: clamp(20px,3vw,32px) 0; }
/* Líneas del h1 — overflow hidden para el slide-up reveal */
.sh-h1 .ln { display: block; overflow: hidden; }
.sh-h1 .ln span { display: block; transform: translateY(105%); }

.sh-sub {
  font-size: clamp(15px,1.4vw,18px);
  color: var(--w60);
  line-height: 1.7;
  max-width: 480px;
  opacity: 0;
}

.sh-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: clamp(24px,3.5vw,40px);
  opacity: 0;
}

.sh-pill {
  display: inline-block;
  text-decoration: none;
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: 12px;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--w60);
  border: 1px solid var(--w12);
  border-radius: 100px;
  padding: 8px 20px;
  background: transparent;
  cursor: none;
  transition: .35s var(--ease);
}
.sh-pill:hover { color: #fff; border-color: var(--n); background: rgba(232,78,27,.1); }

/* Collage flotante */
.sh-collage {
  position: relative;
  height: clamp(360px,45vw,520px);
}

.hc {
  position: absolute;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 24px 60px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.07);
  opacity: 0; /* GSAP anima entrada */
}
.hc img, .hc video {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  pointer-events: none;
  -webkit-user-drag: none;
}

.hc-1 { width: clamp(180px,20vw,260px); height: clamp(240px,28vw,340px); top: 0;    right: clamp(60px,8vw,120px); transform: rotate(-5deg); z-index: 3; }
.hc-2 { width: clamp(150px,17vw,210px); height: clamp(190px,22vw,270px); top: clamp(60px,8vw,100px); right: clamp(240px,28vw,360px); transform: rotate(4deg);  z-index: 2; }
.hc-3 { width: clamp(110px,12vw,150px); height: clamp(110px,12vw,150px); bottom: clamp(20px,4vw,40px); right: clamp(160px,20vw,250px); transform: rotate(-2deg); z-index: 1; border-radius: 50%; }

@media (max-width: 768px) {
  .sh-grid { grid-template-columns: 1fr; gap: 40px; }
  .sh-collage {
    height: 220px;
    display: flex; gap: 14px; align-items: center; justify-content: center;
  }
  .hc { position: static; transform: none !important; }
  .hc-1 { width: 120px; height: 150px; }
  .hc-2 { width: 100px; height: 130px; }
  .hc-3 { width: 90px;  height: 90px; }
}

/* ── STICKY NAV (CÁPSULA FLOTANTE PREMIUM) ── */
#serv-nav {
  position: sticky;
  top: 92px; /* Mayor espacio (28px) por debajo del navbar colapsado de 64px para dar aire visual */
  z-index: 200;
  width: max-content;
  max-width: calc(100vw - 40px);
  margin: 24px auto;
  background: rgba(0, 16, 42, 0.78);
  backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 100px;
  padding: 6px;
  box-shadow: 
    0 16px 36px rgba(0, 0, 0, 0.5), 
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
  /* Oculto por defecto */
  opacity: 0;
  visibility: hidden;
  transform: translateY(-10px) scale(0.95);
  transition: 
    opacity 0.4s var(--ease), 
    visibility 0.4s var(--ease), 
    transform 0.4s var(--ease);
}
#serv-nav.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0) scale(1);
}
.sn-inner {
  display: flex;
  gap: 4px;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}
.sn-inner::-webkit-scrollbar { display: none; }

.sn-pill {
  flex-shrink: 0;
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--w60);
  border: 1px solid transparent;
  border-radius: 100px;
  padding: 7px 16px;
  background: transparent;
  cursor: none;
  transition: .3s var(--ease);
  white-space: nowrap;
}
.sn-pill:hover { 
  color: #fff; 
  background: var(--n); 
  border-color: var(--n); 
}
.sn-pill.active { 
  color: var(--n); 
  font-weight: 700;
}

/* ── BENTO ── */
#serv-bento { background: var(--ink); }

.bento-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: clamp(10px,1.2vw,14px);
}

/* Spans de cada card */
.bc-01 { grid-column: span 4; grid-row: span 2; min-height: 540px; }
.bc-02 { grid-column: span 4; min-height: 260px; }
.bc-03 { grid-column: span 4; min-height: 260px; }
.bc-04 { grid-column: span 8; min-height: 260px; }
.bc-05 { grid-column: span 4; min-height: 260px; }
.bc-06 { grid-column: span 8; min-height: 260px; }

.bc {
  position: relative;
  overflow: hidden;
  border-radius: 10px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  text-decoration: none;
  cursor: none;
  border: 1px solid var(--w06);
  transition: border-color .4s var(--ease), transform .6s var(--ease);
}
.bc:hover { border-color: rgba(232,78,27,.35); }
.bc:hover .bc-img { transform: scale(1.06); }
.bc:hover .bc-title { color: var(--n); }
.bc:hover .bc-arrow { opacity: 1; transform: none; border-color: var(--n); background: var(--n); }

/* Fondo — imagen o gradiente */
.bc-img {
  position: absolute; inset: 0;
  background-position: center;
  background-size: cover;
  background-repeat: no-repeat;
  transition: transform .9s var(--ease);
}
.bc-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,12,36,.95) 0%, rgba(0,12,36,.45) 55%, rgba(0,12,36,.15) 100%);
}

.bc-num {
  position: absolute; top: 20px; left: 22px; z-index: 2;
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: 12px; font-weight: 700;
  color: rgba(255,255,255,.3);
  letter-spacing: .2em; text-transform: uppercase;
}

.bc-body { position: relative; z-index: 2; padding: clamp(18px,2.5vw,28px); }

.bc-chips { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
.bc-chip {
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: 10px; letter-spacing: .14em; text-transform: uppercase;
  color: var(--n);
  border: 1px solid rgba(232,78,27,.35);
  border-radius: 100px;
  padding: 4px 12px;
}

.bc-title {
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-weight: 800; text-transform: uppercase;
  font-size: clamp(20px,2.2vw,32px);
  line-height: 1; letter-spacing: -.02em;
  color: #fff; margin-bottom: 10px;
  transition: color .35s;
}
.bc-desc { font-size: 13px; color: var(--w60); line-height: 1.55; max-width: 340px; }

.bc-arrow {
  position: absolute; top: 18px; right: 18px; z-index: 2;
  width: 42px; height: 42px;
  border: 1px solid var(--w12); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transform: translate(-6px, 6px);
  transition: .4s var(--ease);
}
.bc-arrow svg { width: 15px; height: 15px; stroke: #fff; }

.bc-protect { position: absolute; inset: 0; z-index: 1; }

@media (max-width: 1024px) {
  .bento-grid { grid-template-columns: repeat(6,1fr); }
  .bc-01,.bc-02,.bc-03 { grid-column: span 3; grid-row: span 1; min-height: 280px; }
  .bc-04,.bc-05,.bc-06 { grid-column: span 3; min-height: 280px; }
}
@media (max-width: 680px) {
  .bento-grid { grid-template-columns: 1fr; }
  .bc { grid-column: span 1 !important; min-height: 260px !important; }
  .bc-01 { grid-row: span 1; }
}

/* ── GALERÍA FILM STRIPS ── */
#galeria { background: var(--bg); }

.gal-header { margin-bottom: clamp(28px,4vw,48px); }
.gal-header .lead { margin-top: 12px; margin-bottom: 16px; }
.gal-header > p { color: var(--w60); font-size: 16px; }

.gal-filters {
  display: flex; gap: 10px; flex-wrap: wrap;
  margin-top: clamp(20px,3vw,32px);
}
.gal-pill {
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: 12px; letter-spacing: .14em; text-transform: uppercase;
  color: var(--w60); border: 1px solid var(--w12);
  border-radius: 100px; padding: 9px 22px;
  background: transparent; cursor: none;
  transition: .35s var(--ease);
}
.gal-pill:hover { border-color: rgba(232,78,27,.4); color: #fff; }
.gal-pill.active { background: var(--n); border-color: var(--n); color: #fff; }

/* Contenedor de tiras */
.gal-strip {
  display: grid;
  grid-template-columns: repeat(5, 1fr);   /* 5 cols — "Todos" */
  gap: clamp(8px, 1vw, 12px);
  height: 90vh;
  min-height: 560px;
  overflow: hidden;
  margin-top: clamp(28px,4vw,48px);
  mask-image: linear-gradient(to bottom, transparent 0%, #000 7%, #000 93%, transparent 100%);
  -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 7%, #000 93%, transparent 100%);
}
/* 4 cols cuando hay filtro activo — oculta la 5ª columna */
.gal-strip.is-filtered {
  grid-template-columns: repeat(4, 1fr);
}
.gal-strip.is-filtered .gal-col:last-child {
  display: none;
}

.gal-col { overflow: hidden; position: relative; }

.gal-track {
  display: flex; flex-direction: column;
  gap: clamp(8px, 1vw, 12px);
  will-change: transform;
}

/* Columnas impares suben, pares bajan — delay por columna vía --dly */
.gal-col-up .gal-track {
  animation: strip-up var(--spd,240s) linear infinite;
  animation-delay: var(--dly, 0s);
}
.gal-col-down .gal-track {
  animation: strip-down var(--spd,270s) linear infinite;
  animation-delay: var(--dly, 0s);
}
.gal-col:hover .gal-track { animation-play-state: paused; }

@keyframes strip-up {
  from { transform: translateY(0); }
  to   { transform: translateY(-50%); }
}
@keyframes strip-down {
  from { transform: translateY(-50%); }
  to   { transform: translateY(0); }
}

/* Ítem dentro de la tira */
.gal-si {
  position: relative; border-radius: 8px; overflow: hidden; flex-shrink: 0;
  transition: opacity .45s var(--ease), transform .45s var(--ease);
}
.gal-si.gal-si-hidden { opacity: .06; transform: scale(.96); pointer-events: none; }
/* Imágenes con alturas variadas — patrón de 6 para ritmo visual orgánico */
.gal-si img {
  width: 100%; display: block;
  object-fit: cover;
  pointer-events: none; -webkit-user-drag: none;
  transition: transform .9s var(--ease);
}
.gal-si:hover img { transform: scale(1.04); }

/* Patrón rotativo de 6 alturas:
   cuadrados, rectangulos altos, y proporciones intermedias */
.gal-si:nth-child(6n+1) img { height: clamp(180px,17vw,260px); }   /* medio-alto */
.gal-si:nth-child(6n+2) img { height: clamp(140px,13vw,190px); }   /* casi cuadrado */
.gal-si:nth-child(6n+3) img { height: clamp(240px,23vw,340px); }   /* alto / retrato */
.gal-si:nth-child(6n+4) img { height: clamp(150px,14vw,200px); }   /* cuadrado */
.gal-si:nth-child(6n+5) img { height: clamp(200px,19vw,280px); }   /* medio */
.gal-si:nth-child(6n+6) img { height: clamp(110px,10vw,160px); }   /* panorámico / bajo */

.gal-protect { position: absolute; inset: 0; z-index: 2; }

.gal-badge {
  position: absolute; bottom: 12px; left: 14px; z-index: 3;
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: 10px; letter-spacing: .14em; text-transform: uppercase;
  color: var(--n); background: rgba(0,16,42,.82);
  border: 1px solid rgba(232,78,27,.3); border-radius: 100px; padding: 4px 12px;
  opacity: 0; transform: translateY(6px); transition: .35s var(--ease);
}
.gal-si:hover .gal-badge { opacity: 1; transform: none; }

/* Spotlight naranja por cursor */
.gal-si::after {
  content: ''; position: absolute; inset: 0; z-index: 3; pointer-events: none;
  opacity: 0; border-radius: inherit;
  background: radial-gradient(160px at var(--mx,50%) var(--my,50%), rgba(232,78,27,.12), transparent 70%);
  transition: opacity .3s;
}
.gal-si:hover::after { opacity: 1; }

.gal-empty {
  margin-top: clamp(28px,4vw,48px); padding: clamp(40px,6vw,80px) 0;
  text-align: center; border: 1px dashed var(--w12); border-radius: 10px;
}
.gal-empty p { color: var(--w60); font-size: 16px; margin-bottom: 12px; }
.gal-empty span { font-size: 13px; color: var(--w40); }
.gal-empty code { color: var(--n); background: rgba(232,78,27,.08); border: 1px solid rgba(232,78,27,.2); padding: 2px 8px; border-radius: 4px; font-family: monospace; }

@media (max-width: 1280px) { .gal-strip { grid-template-columns: repeat(4, 1fr); } .gal-strip.is-filtered { grid-template-columns: repeat(3, 1fr); } .gal-strip .gal-col:last-child { display: block; } .gal-strip.is-filtered .gal-col:last-child { display: none; } }
@media (max-width: 900px)  { .gal-strip { grid-template-columns: repeat(3, 1fr) !important; height: 76vh; } .gal-strip .gal-col:last-child,.gal-strip.is-filtered .gal-col:last-child { display: block; } }
@media (max-width: 580px)  { .gal-strip { grid-template-columns: repeat(2, 1fr) !important; height: 62vh; } }

/* ── CTA DOBLE ── */
.cto-serv-section {
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
.cto-container {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(24px, 4vw, 48px);
}
.cto-card {
  position: relative;
  background: rgba(255, 255, 255, 0.02);
  backdrop-filter: blur(12px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 20px;
  padding: clamp(30px, 5vw, 56px);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  transition: border-color 0.4s var(--ease), background 0.4s var(--ease), transform 0.4s var(--ease);
  overflow: hidden;
}
.cto-card:hover {
  border-color: rgba(232, 78, 27, 0.35);
  background: rgba(255, 255, 255, 0.03);
  transform: translateY(-4px);
}
.cto-card-glow {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(
    300px circle at var(--mx, 50%) var(--my, 50%),
    rgba(232, 78, 27, 0.08),
    transparent 65%
  );
  opacity: 0;
  transition: opacity 0.4s var(--ease);
  z-index: 0;
}
.cto-card:hover .cto-card-glow {
  opacity: 1;
}
.cto-card-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 24px;
  position: relative;
  z-index: 1;
}
.cto-card-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: rgba(232, 78, 27, 0.08);
  border: 1px solid rgba(232, 78, 27, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--n);
  transition: transform 0.4s var(--ease), background 0.4s var(--ease);
}
.cto-card:hover .cto-card-icon {
  transform: scale(1.1) rotate(5deg);
  background: rgba(232, 78, 27, 0.15);
}
.cto-card-icon svg {
  width: 24px;
  height: 24px;
}
.cto-card-kicker {
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--w40);
}
.cto-card-title {
  font-family: 'Sofia Sans Condensed', sans-serif;
  font-size: clamp(24px, 3vw, 42px);
  font-weight: 900;
  text-transform: uppercase;
  color: #fff;
  margin: 0 0 16px 0;
  line-height: 1;
  letter-spacing: -0.02em;
  position: relative;
  z-index: 1;
}
.cto-card-desc {
  font-size: clamp(14px, 1.2vw, 16px);
  color: var(--w60);
  line-height: 1.65;
  margin: 0 0 36px 0;
  max-width: 480px;
  flex-grow: 1;
  position: relative;
  z-index: 1;
}
.cto-card-btn {
  position: relative;
  z-index: 1;
}
.btn-outline {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: transparent;
  color: #fff;
  text-decoration: none;
  padding: 17px 30px;
  border-radius: 100px;
  font-weight: 600;
  font-size: 15px;
  border: 1px solid rgba(255, 255, 255, 0.15);
  font-family: 'Sofia Sans', sans-serif;
  cursor: none;
  transition: background 0.3s, border-color 0.3s, color 0.3s;
}
.btn-outline:hover {
  background: #fff;
  border-color: #fff;
  color: var(--ink);
}
.btn-outline svg {
  width: 16px;
  height: 16px;
  transition: transform 0.3s;
}
.btn-outline:hover svg {
  transform: translateX(4px);
  stroke: var(--ink);
}
@media (max-width: 860px) {
  .cto-container {
    grid-template-columns: 1fr;
    gap: 24px;
  }
}
</style>

<!-- ═══════════════════════════════════════════════════════════
     SCRIPTS
════════════════════════════════════════════════════════════ -->
<script>
  import { gsap, ScrollTrigger } from '../../utils/gsap-config';

  /* ── 1. ANIMACIÓN DE ENTRADA DEL HERO ──────────────────── */
  const prefersRM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersRM) {
    // Seteamos el estado inicial en JS de inmediato para evitar FOUC
    gsap.set('#sh-idx',   { opacity: 0, y: 16 });
    gsap.set('#sh-sub',   { opacity: 0, y: 20 });
    gsap.set('#sh-pills', { opacity: 0, y: 16 });

    gsap.timeline({ defaults: { ease: 'power4.out' } })
      // Label índice
      .to('#sh-idx',            { opacity: 1, y: 0, duration: .6 }, .15)
      // Líneas del h1 — slide-up desde overflow hidden (animación a 0%)
      .to('#sh-h1 .ln span',      { y: '0%', stagger: .12, duration: .9 }, .25)
      // Subtítulo
      .to('#sh-sub',              { opacity: 1, y: 0, duration: .7 }, '-=.5')
      // Pills de acceso rápido
      .to('#sh-pills',            { opacity: 1, y: 0, duration: .6 }, '-=.4')
      // Collage flotante — cada foto entra desde abajo con leve rotación adicional (fromTo para forzar visibilidad)
      .fromTo('.hc-1', { opacity: 0, y: 50, rotation: -12 }, { opacity: 1, y: 0, rotation: -5, duration: .8 }, '-=.4')
      .fromTo('.hc-2', { opacity: 0, y: 60, rotation:   8 }, { opacity: 1, y: 0, rotation: 4,  duration: .8 }, '-=.65')
      .fromTo('.hc-3', { opacity: 0, y: 40, rotation:  -6 }, { opacity: 1, y: 0, rotation: -2, duration: .7 }, '-=.6');
  } else {
    // Sin animación — mostrar directo
    gsap.set('.hc', { opacity: 1, y: 0 });
    gsap.set('#sh-h1 .ln span', { y: 0 });
  }

  /* ── 2. STICKY NAV — REDIRECCIÓN DIRECTA (SIN SCROLL HIGHLIGHT) ── */
  ScrollTrigger.create({
    trigger: '#hero',
    start: 'bottom top+=92',
    onEnter: () => document.getElementById('serv-nav')?.classList.add('visible'),
    onLeaveBack: () => document.getElementById('serv-nav')?.classList.remove('visible'),
    onRefresh: (self) => {
      const nav = document.getElementById('serv-nav');
      if (self.progress > 0) {
        nav?.classList.add('visible');
      } else {
        nav?.classList.remove('visible');
      }
    }
  });

  /* ── 3. BENTO CARDS — 3D MOUSE TRACKING ────────────────── */
  document.querySelectorAll<HTMLElement>('.bc').forEach(card => {
    const setRX = gsap.quickSetter(card, 'rotateX', 'deg');
    const setRY = gsap.quickSetter(card, 'rotateY', 'deg');
    gsap.set(card, { transformPerspective: 900 });

    card.addEventListener('mousemove', (e: MouseEvent) => {
      const r  = card.getBoundingClientRect();
      const nx = (e.clientX - r.left) / r.width  - 0.5;
      const ny = (e.clientY - r.top)  / r.height - 0.5;
      setRX(-ny * 7);
      setRY( nx * 7);
    });

    card.addEventListener('mouseleave', () => {
      gsap.to(card, { rotateX: 0, rotateY: 0, duration: .6, ease: 'power3.out' });
    });
  });

  /* ── 4. FILM STRIPS — FILTER ────────────────────────────── */
  const pills  = document.querySelectorAll<HTMLButtonElement>('.gal-pill');
  const strip  = document.getElementById('galStrip');
  let   active = '*';

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter ?? '*';
      if (filter === active) return;
      active = filter;

      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');

      const isAll = filter === '*';

      /* Pausa los strips al filtrar (se reanudan al volver a "Todos") */
      strip?.classList.toggle('is-filtered', !isAll);

      /* Atenúa ítems que no coinciden en AMBOS sets (A y B del loop) */
      document.querySelectorAll<HTMLElement>('.gal-si').forEach(si => {
        const match = isAll || si.dataset.cat === filter;
        si.classList.toggle('gal-si-hidden', !match);
      });
    });
  });

  /* ── 5. FILM STRIPS — SPOTLIGHT POR CURSOR ──────────────── */
  document.querySelectorAll<HTMLElement>('.gal-si').forEach(si => {
    si.addEventListener('mousemove', (e: MouseEvent) => {
      const r = si.getBoundingClientRect();
      si.style.setProperty('--mx', `${((e.clientX - r.left) / r.width  * 100).toFixed(1)}%`);
      si.style.setProperty('--my', `${((e.clientY - r.top)  / r.height * 100).toFixed(1)}%`);
    });
  });

  /* ── 6. SCROLL REVEALS ──────────────────────────────────── */

  // 6a — data-d: elementos con delay escalonado (header, subtítulos, pills…)
  gsap.utils.toArray<HTMLElement>('[data-d]').forEach(el => {
    const d = parseFloat(el.dataset.d ?? '0') * 0.08;
    ScrollTrigger.create({
      trigger: el,
      start: 'top 88%',
      onEnter: () => {
        gsap.to(el, { opacity: 1, y: 0, duration: .9, delay: d, ease: 'power4.out' });
      },
      once: true,
    });
  });

  // 6b — (Film strips usan CSS animations — sin GSAP reveal necesario)

  /* ── 9. PROTECCIÓN DE IMÁGENES ──────────────────────────── */
  ['#galeria','#serv-bento'].forEach(sel => {
    document.querySelector(sel)?.addEventListener('contextmenu', e => e.preventDefault());
    document.querySelector(sel)?.addEventListener('dragstart',   e => e.preventDefault());
  });

  /* ── 10. CTA — abrir ContactDialog ──────────────────────── */
  document.getElementById('openContactServ')?.addEventListener('click', () => {
    document.querySelector<HTMLDialogElement>('#contact-dialog')?.showModal();
  });

  /* ── 11. CTA CARDS — SPOTLIGHT DE CURSOR ───────────────── */
  document.querySelectorAll<HTMLElement>('.cto-card').forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const r = card.getBoundingClientRect();
      card.style.setProperty('--mx', `${e.clientX - r.left}px`);
      card.style.setProperty('--my', `${e.clientY - r.top}px`);
    });
  });
</script>

