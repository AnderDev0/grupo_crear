---
const brands = [
  { name: 'Marca Colombia', logo: '/logos/co-colombia.svg' },
  { name: 'ProColombia', logo: '/logos/procolombia.svg' },
  { name: 'ANATO', logo: '/logos/anato.svg' },
  { name: 'Greater Bogota', logo: '/logos/greater-bogota.svg' },
  { name: 'USAID', logo: '/logos/usaid.svg' },
  { name: 'ACOTUR', logo: '/logos/acotur.svg' },
  { name: 'Colombia Potencia de la Vida', logo: '/logos/colombia-potencia.svg' },
];

// Duplicate the array to ensure seamless infinite looping
const doubleBrands = [...brands, ...brands];
---

<div class="marquee-brands" aria-hidden="true">
  <div class="mq-track-brands">
    {doubleBrands.map((brand) => (
      <div class="brand-item">
        <img src={brand.logo} alt={brand.name} loading="lazy" />
      </div>
    ))}
  </div>
</div>

<style>
  .marquee-brands {
    border-top: 1px solid var(--w06);
    border-bottom: 1px solid var(--w06);
    padding: clamp(24px, 3.5vw, 44px) 0;
    overflow: hidden;
    background: var(--ink);
    display: flex;
    width: 100%;
    /* Smooth gradient mask for edge fading */
    mask-image: linear-gradient(to right, transparent, white 15%, white 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, white 15%, white 85%, transparent);
  }

  .mq-track-brands {
    display: flex;
    gap: clamp(48px, 7vw, 110px);
    width: max-content;
    animation: scroll-brands 34s linear infinite;
    align-items: center;
  }

  .marquee-brands:hover .mq-track-brands {
    animation-play-state: paused;
  }

  .brand-item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: clamp(120px, 14vw, 170px);
    height: 42px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .brand-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.35;
    filter: grayscale(1) brightness(0) invert(1); /* Ensures clean white-ish monochrome logos */
    transition: opacity 0.4s ease, filter 0.4s ease, transform 0.4s ease;
  }

  /* When hovering the individual logo, make it solid white and apply a premium subtle scale */
  .brand-item:hover img {
    opacity: 0.9;
    filter: grayscale(0) brightness(1) invert(0); /* Reveal original details or full white depending on styles */
  }

  .brand-item:hover {
    transform: translateY(-2px);
  }

  @keyframes scroll-brands {
    to {
      transform: translateX(-50%);
    }
  }

  /* Accessibility support for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .mq-track-brands {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 32px 48px;
    }
    .marquee-brands {
      mask-image: none;
      -webkit-mask-image: none;
      overflow: visible;
      padding: clamp(30px, 4vw, 50px) 24px;
    }
  }
</style>
