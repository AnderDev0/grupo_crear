---
import LogoDisplace from './LogoDisplace.astro';
import MeteorScroll from './MeteorScroll.astro';

export interface Props {
  tagline?: string;
  subtitulo?: string;
}

const {
  tagline = 'Creamos impacto visual',
  subtitulo = 'Producción publicitaria, branding y gran formato con alma industrial. Transformamos ideas en experiencias que mueven marcas.',
} = Astro.props;
---

<!-- Scroll space que da recorrido al ScrollTrigger del meteoro -->
<div id="hero-scroll-space" style="position:relative;min-height:300vh;">

  <!-- Sección hero fijada durante el scroll -->
  <section
    id="hero-pinned"
    aria-label="Hero principal"
    style="position:sticky;top:0;height:100vh;overflow:hidden;display:grid;grid-template-columns:1fr;align-items:center;"
  >
    <!-- Fondo radial extra sobre el gradiente base del Layout -->
    <div
      aria-hidden="true"
      style="position:absolute;inset:0;z-index:0;background:radial-gradient(ellipse 70% 60% at 20% 50%, rgba(0,25,74,0.7) 0%, transparent 70%);"
    ></div>

    <!-- Grid principal desktop: texto izq / meteoro der -->
    <div
      id="hero-grid"
      style="
        position:relative;
        z-index:2;
        display:grid;
        grid-template-columns:1fr 1fr;
        grid-template-rows:1fr;
        height:100%;
        max-width:1440px;
        margin:0 auto;
        padding:0 clamp(1.5rem,5vw,6rem);
        gap:2rem;
        align-items:center;
      "
    >
      <!-- Columna izquierda: logo + texto + CTA -->
      <div id="hero-text-col" style="display:flex;flex-direction:column;gap:2rem;z-index:3;">

        <!-- Logo con efecto líquido -->
        <div id="hero-logo" style="opacity:0;transform:translateY(-20px);">
          <LogoDisplace width={200} height={72} />
        </div>

        <!-- Scroll progress indicator -->
        <div
          id="scroll-progress-track"
          aria-hidden="true"
          style="
            position:absolute;
            left:clamp(0.75rem,2vw,1.5rem);
            top:50%;
            transform:translateY(-50%);
            width:2px;
            height:120px;
            background:rgba(240,244,255,0.1);
            border-radius:1px;
          "
        >
          <div
            id="scroll-progress-fill"
            style="
              width:100%;
              height:0%;
              background:var(--accent);
              border-radius:1px;
              box-shadow:0 0 8px var(--accent-glow);
              transition:none;
            "
          ></div>
        </div>

        <div>
          <h1
            id="hero-tagline"
            style="
              font-family:var(--font-condensed);
              font-size:clamp(2.8rem,6.5vw,6rem);
              font-weight:900;
              line-height:0.95;
              color:var(--text-primary);
              letter-spacing:-0.02em;
              opacity:0;
              transform:translateY(30px);
            "
          >
            {tagline.split(' ').map((word, i) => (
              <span
                class="hero-word"
                style={`display:inline-block;margin-right:0.25em;${i === tagline.split(' ').length - 1 ? 'color:var(--accent);' : ''}`}
              >
                {word}
              </span>
            ))}
          </h1>
        </div>

        <p
          id="hero-subtitle"
          style="
            font-family:var(--font-sans);
            font-size:clamp(1rem,1.6vw,1.25rem);
            font-weight:400;
            line-height:1.6;
            color:var(--text-secondary);
            max-width:42ch;
            opacity:0;
            transform:translateY(20px);
          "
        >
          {subtitulo}
        </p>

        <div id="hero-cta" style="opacity:0;transform:translateY(16px);">
          <button
            id="open-contact-btn"
            type="button"
            style="
              display:inline-flex;
              align-items:center;
              gap:0.6rem;
              background:var(--accent);
              color:#fff;
              font-family:var(--font-condensed);
              font-size:1.1rem;
              font-weight:700;
              letter-spacing:0.04em;
              text-transform:uppercase;
              padding:0.85rem 2rem;
              border:none;
              border-radius:3px;
              cursor:none;
              position:relative;
              overflow:hidden;
              transition:background 0.2s,box-shadow 0.2s;
            "
            onmouseenter="this.style.background='var(--accent-dark)';this.style.boxShadow='0 0 24px var(--accent-glow)'"
            onmouseleave="this.style.background='var(--accent)';this.style.boxShadow='none'"
          >
            Ver nuestro trabajo
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

      </div>

      <!-- Columna derecha: meteoro -->
      <div
        id="hero-meteor-col"
        style="
          position:relative;
          height:100%;
          display:flex;
          align-items:center;
          justify-content:center;
          overflow:visible;
          opacity:0;
          transform:translateY(60px);
        "
      >
        <MeteorScroll />
      </div>
    </div>

    <!-- Overlay gradiente para legibilidad en desktop -->
    <div
      aria-hidden="true"
      style="
        position:absolute;
        inset:0;
        z-index:1;
        pointer-events:none;
        background:linear-gradient(to right, var(--bg-primary) 20%, rgba(0,20,51,0.6) 45%, transparent 65%);
      "
    ></div>

    <!-- Indicador de scroll (chevron) -->
    <div
      id="scroll-hint"
      aria-hidden="true"
      style="
        position:absolute;
        bottom:2rem;
        left:50%;
        transform:translateX(-50%);
        z-index:5;
        display:flex;
        flex-direction:column;
        align-items:center;
        gap:0.4rem;
        opacity:0;
      "
    >
      <span style="font-family:var(--font-sans);font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-secondary);">scroll</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M5 8l5 5 5-5" stroke="var(--accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

  </section>
</div>

<style>
  @media (max-width: 767px) {
    #hero-grid {
      grid-template-columns: 1fr !important;
      grid-template-rows: auto 1fr !important;
      padding: 0 1.5rem !important;
      align-items: start !important;
      padding-top: 5rem !important;
    }
    #hero-meteor-col {
      position: absolute !important;
      inset: 0 !important;
      z-index: 0 !important;
      opacity: 1 !important;
      transform: none !important;
    }
    #hero-text-col {
      z-index: 2 !important;
      padding-top: 40vh !important;
    }
    #hero-pinned::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, var(--bg-primary) 30%, rgba(0,20,51,0.5) 70%, transparent);
      z-index: 1;
      pointer-events: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  (function () {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // --- Animación de entrada (page load) ---
    if (!prefersReduced) {
      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

      tl.to('#hero-logo', { opacity: 1, y: 0, duration: 0.7 }, 0.2)
        .to('#hero-meteor-col', { opacity: 1, y: 0, duration: 1.2 }, 0.1)
        .to('.hero-word', { opacity: 1, y: 0, duration: 0.6, stagger: 0.1 }, 0.55)
        .to('#hero-subtitle', { opacity: 1, y: 0, duration: 0.6 }, 0.95)
        .to('#hero-cta', { opacity: 1, y: 0, duration: 0.5 }, 1.2)
        .to('#scroll-hint', { opacity: 1, duration: 0.5 }, 1.5);

      // Animación bounce del scroll hint
      gsap.to('#scroll-hint svg', {
        y: 6,
        repeat: -1,
        yoyo: true,
        duration: 0.8,
        ease: 'power1.inOut',
        delay: 2,
      });
    } else {
      gsap.set(['#hero-logo','#hero-tagline','#hero-subtitle','#hero-cta','#hero-meteor-col','#scroll-hint'], {
        opacity: 1, y: 0,
      });
      gsap.set('.hero-word', { opacity: 1, y: 0 });
    }

    // --- Scroll: texto desaparece + progress bar ---
    if (!prefersReduced) {
      ScrollTrigger.create({
        trigger: '#hero-scroll-space',
        start: 'top top',
        end: '30% top',
        scrub: 1,
        onUpdate: (self) => {
          const p = self.progress;
          gsap.set('#hero-text-col', { opacity: 1 - p * 1.8, y: -p * 40 });
          gsap.set('#scroll-progress-fill', { height: `${p * 100}%` });
          gsap.set('#scroll-hint', { opacity: Math.max(0, 1 - p * 4) });
        },
      });
    }

    // --- CTA abre el modal de contacto ---
    const ctaBtn = document.getElementById('open-contact-btn');
    const dialog = document.getElementById('contact-dialog') as HTMLDialogElement | null;
    if (ctaBtn && dialog) {
      ctaBtn.addEventListener('click', () => dialog.showModal());
    }
  })();
</script>
