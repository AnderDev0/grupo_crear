---

<!--
  <dialog> nativo ya tiene role="dialog" implícito — no se repite (Primera Regla de ARIA).
  aria-modal="true" indica a los lectores de pantalla que el contenido fuera está inactivo.
  aria-labelledby vincula el título al dialog para que sea anunciado al abrirlo.
-->
<dialog
  id="contact-dialog"
  aria-modal="true"
  aria-labelledby="dialog-title"
>
  <div class="dialog-inner">
    <!-- Encabezado -->
    <div class="dialog-header">
      <h2 id="dialog-title">Hablemos de tu proyecto</h2>
      <button
        id="dialog-close"
        type="button"
        aria-label="Cerrar modal"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
          <path d="M5 5l10 10M15 5l-10 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Formulario -->
    <form id="contact-form" novalidate>
      <div class="form-fields">

        <!-- Nombre -->
        <div class="field-group">
          <label for="cf-nombre" class="field-label">
            Nombre completo
            <span aria-hidden="true" style="color:var(--accent);">*</span>
          </label>
          <input
            id="cf-nombre"
            name="nombre"
            type="text"
            required
            aria-required="true"
            aria-describedby="err-nombre"
            minlength="2"
            maxlength="100"
            autocomplete="name"
            class="field-input"
            placeholder="Tu nombre"
          />
          <span class="field-error" aria-live="polite" id="err-nombre" role="alert"></span>
        </div>

        <!-- Email -->
        <div class="field-group">
          <label for="cf-email" class="field-label">
            Correo electrónico
            <span aria-hidden="true" style="color:var(--accent);">*</span>
          </label>
          <input
            id="cf-email"
            name="email"
            type="email"
            required
            aria-required="true"
            aria-describedby="err-email"
            maxlength="254"
            autocomplete="email"
            class="field-input"
            placeholder="tu@correo.com"
          />
          <span class="field-error" aria-live="polite" id="err-email" role="alert"></span>
        </div>

        <!-- Empresa -->
        <div class="field-group">
          <label for="cf-empresa" class="field-label">
            Empresa
            <span style="color:var(--text-secondary);font-weight:400;">(opcional)</span>
          </label>
          <input
            id="cf-empresa"
            name="empresa"
            type="text"
            maxlength="100"
            autocomplete="organization"
            class="field-input"
            placeholder="Nombre de tu empresa"
          />
        </div>

        <!-- Mensaje -->
        <div class="field-group">
          <label for="cf-mensaje" class="field-label">
            Mensaje
            <span aria-hidden="true" style="color:var(--accent);">*</span>
          </label>
          <textarea
            id="cf-mensaje"
            name="mensaje"
            required
            aria-required="true"
            aria-describedby="err-mensaje"
            minlength="10"
            maxlength="2000"
            rows="4"
            class="field-input"
            placeholder="Cuéntanos sobre tu proyecto..."
            style="resize:vertical;min-height:100px;"
          ></textarea>
          <span class="field-error" aria-live="polite" id="err-mensaje" role="alert"></span>
        </div>

        <!-- Respuesta del servidor -->
        <div id="form-response" aria-live="assertive" aria-atomic="true" style="display:none;padding:0.75rem 1rem;border-radius:4px;font-size:0.9rem;"></div>

        <!-- Submit -->
        <button
          id="cf-submit"
          type="submit"
        >
          <span id="cf-submit-text">Enviar mensaje</span>
          <span id="cf-submit-spinner" style="display:none;" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="animation:spin 0.8s linear infinite;">
              <circle cx="9" cy="9" r="7" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
              <path d="M9 2a7 7 0 0 1 7 7" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>

      </div>
    </form>
  </div>
</dialog>

<style>
  #contact-dialog {
    --text-primary: #ffffff;
    --text-secondary: rgba(255, 255, 255, 0.6);
    --bg-secondary: #00194a;
    --accent: #E84E1B;
    --accent-dark: #c23e12;
    --accent-glow: rgba(232, 78, 27, 0.4);
    --font-sans: 'Sofia Sans', sans-serif;
    --font-condensed: 'Sofia Sans Condensed', sans-serif;

    border: none;
    background: transparent;
    padding: 0;
    max-width: min(560px, 95vw);
    width: 100%;

    /* Centrado absoluto ultra-robusto */
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;
  }

  .dialog-inner {
    background: rgba(4, 16, 42, 0.95);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(232, 78, 27, 0.3);
    border-radius: 16px;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    position: relative;
    box-shadow: 
      0 24px 80px rgba(0, 0, 0, 0.7), 
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .dialog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.75rem;
  }

  #dialog-title {
    font-family: var(--font-condensed);
    font-size: 1.8rem;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }

  #dialog-close {
    background: none;
    border: none;
    color: var(--text-secondary);
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    transition: color 0.2s, background-color 0.2s;
    min-width: 44px;
    min-height: 44px;
    cursor: none;
  }
  #dialog-close:hover {
    color: var(--accent);
    background-color: rgba(255, 255, 255, 0.05);
  }

  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  dialog::backdrop {
    background: rgba(0, 10, 30, 0.75);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  dialog[open] {
    animation: dialog-in 0.28s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes dialog-in {
    from { opacity: 0; transform: translate(-50%, -46%) scale(0.92); }
    to   { opacity: 1; transform: translate(-50%, -50%) scale(1);    }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  dialog:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .field-label {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .field-input {
    background: rgba(0, 10, 30, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
  }

  .field-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .field-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(232, 78, 27, 0.25);
  }

  .field-input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }

  .field-input.invalid {
    border-color: #e84e1b;
  }

  .field-error {
    font-size: 0.78rem;
    color: #ff7a5a;
    min-height: 1em;
    font-family: var(--font-sans);
  }

  #cf-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 16px 30px;
    min-height: 48px;
    border: none;
    border-radius: 100px;
    width: 100%;
    margin-top: 0.5rem;
    transition: background 0.3s, box-shadow 0.3s, transform 0.3s;
    position: relative;
    overflow: hidden;
    cursor: none;
  }
  #cf-submit:hover:not(:disabled) {
    background: var(--accent-dark);
    box-shadow: 0 8px 24px rgba(232, 78, 27, 0.4);
    transform: translateY(-2px);
  }
  #cf-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script>
  import { gsap } from 'gsap';

  (function () {
    const dialog      = document.getElementById('contact-dialog') as HTMLDialogElement | null;
    const closeBtn    = document.getElementById('dialog-close');
    const form        = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn   = document.getElementById('cf-submit') as HTMLButtonElement | null;
    const submitText  = document.getElementById('cf-submit-text');
    const submitSpinner = document.getElementById('cf-submit-spinner');
    const formResponse  = document.getElementById('form-response');

    if (!dialog || !closeBtn || !form || !submitBtn) return;

    // Guarda referencia al elemento que tenía el foco antes de abrir el modal.
    // Se restaura al cerrar para que el usuario de teclado retome su posición.
    let previousFocus: HTMLElement | null = null;

    // MutationObserver detecta cuando el atributo "open" se agrega al <dialog>.
    // showModal() es síncrono, así que el atributo ya está presente en el callback.
    const openObserver = new MutationObserver(() => {
      if (dialog.open) {
        previousFocus = document.activeElement as HTMLElement;
        // Mueve el foco al primer campo del formulario al abrir el modal
        const firstInput = dialog.querySelector<HTMLElement>('input,textarea');
        if (firstInput) firstInput.focus();
      }
    });
    openObserver.observe(dialog, { attributes: true, attributeFilter: ['open'] });

    function closeDialog() {
      dialog.close();
      // Restaura el foco al elemento que abrió el modal
      if (previousFocus) previousFocus.focus();
    }

    closeBtn.addEventListener('click', closeDialog);

    // Cierra al hacer clic en el backdrop (fuera del contenido del dialog)
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeDialog();
    });

    // Restaura foco también cuando se cierra con la tecla Escape (nativo del <dialog>)
    dialog.addEventListener('close', () => {
      if (previousFocus) previousFocus.focus();
    });

    // Focus trap: mantiene el foco dentro del modal con Tab y Shift+Tab
    dialog.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      const focusable = Array.from(
        dialog.querySelectorAll<HTMLElement>(
          'button,input,textarea,select,[tabindex]:not([tabindex="-1"])'
        )
      ).filter((el) => !el.hasAttribute('disabled'));
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last  = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
      }
    });

    // Validación visual inline
    function validateField(input: HTMLInputElement | HTMLTextAreaElement): boolean {
      const errEl = document.getElementById(`err-${input.name}`);
      if (!input.validity.valid) {
        input.classList.add('invalid');
        // aria-invalid comunica el estado de error al lector de pantalla
        input.setAttribute('aria-invalid', 'true');
        if (errEl) errEl.textContent = input.validationMessage;
        return false;
      }
      input.classList.remove('invalid');
      input.setAttribute('aria-invalid', 'false');
      if (errEl) errEl.textContent = '';
      return true;
    }

    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input,textarea').forEach((field) => {
      field.addEventListener('blur', () => validateField(field));
    });

    // Envío
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const fields    = Array.from(form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input,textarea'));
      const allValid  = fields.map(validateField).every(Boolean);
      if (!allValid) return;

      const payload = {
        nombre:  (form.querySelector<HTMLInputElement>('#cf-nombre')!).value.trim(),
        email:   (form.querySelector<HTMLInputElement>('#cf-email')!).value.trim(),
        empresa: (form.querySelector<HTMLInputElement>('#cf-empresa')!).value.trim() || undefined,
        mensaje: (form.querySelector<HTMLTextAreaElement>('#cf-mensaje')!).value.trim(),
      };

      submitBtn.disabled = true;
      if (submitText)    submitText.textContent          = 'Enviando...';
      if (submitSpinner) submitSpinner.style.display     = 'inline-flex';

      try {
        const res  = await fetch('/api/contacto', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();

        if (formResponse) {
          formResponse.style.display = 'block';
          if (res.ok) {
            formResponse.textContent       = data.message ?? '¡Mensaje enviado! Te contactaremos pronto.';
            formResponse.style.background  = 'rgba(27,232,100,0.12)';
            formResponse.style.border      = '1px solid rgba(27,232,100,0.3)';
            formResponse.style.color       = '#6effa0';
            form.reset();
            gsap.delayedCall(3, closeDialog);
          } else {
            const errors = data.errors
              ? Object.values(data.errors.fieldErrors).flat().join(' · ')
              : 'Error al enviar. Intenta de nuevo.';
            formResponse.textContent       = errors as string;
            formResponse.style.background  = 'rgba(232,78,27,0.12)';
            formResponse.style.border      = '1px solid rgba(232,78,27,0.3)';
            formResponse.style.color       = '#ff7a5a';
          }
        }
      } catch {
        if (formResponse) {
          formResponse.style.display     = 'block';
          formResponse.textContent       = 'Error de conexión. Intenta de nuevo.';
          formResponse.style.background  = 'rgba(232,78,27,0.12)';
          formResponse.style.border      = '1px solid rgba(232,78,27,0.3)';
          formResponse.style.color       = '#ff7a5a';
        }
      } finally {
        submitBtn.disabled = false;
        if (submitText)    submitText.textContent      = 'Enviar mensaje';
        if (submitSpinner) submitSpinner.style.display = 'none';
      }
    });
  })();
</script>
