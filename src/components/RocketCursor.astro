<div id="rocketCursor" aria-hidden="true">
  <svg
    id="rocket-svg"
    width="42"
    height="42"
    viewBox="0 0 36 36"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    style="display:block;filter:drop-shadow(0 4px 10px rgba(232,78,27,.45));"
  >
    <!-- Llama del motor (escala reactiva a velocidad) -->
    <g id="rocket-flame" style="transform-origin:18px 32px;">
      <ellipse cx="18" cy="31" rx="4"   ry="5"   fill="#E84E1B" opacity="0.9"/>
      <ellipse cx="18" cy="33" rx="2.5" ry="3.5" fill="#ff8c42" opacity="0.8"/>
      <ellipse cx="18" cy="34.5" rx="1.2" ry="2" fill="#fff"    opacity="0.7"/>
    </g>
    <!-- Cuerpo -->
    <path d="M18 2C18 2 11 10 11 20V26H25V20C25 10 18 2 18 2Z" fill="#E84E1B"/>
    <path d="M11 20V26H25V20C25 10 18 2 18 2C18 2 25 10 25 20Z" fill="#c23e12" opacity="0.4"/>
    <!-- Ventana -->
    <circle cx="18" cy="16" r="3.5" fill="#001433" stroke="#f0f4ff" stroke-width="1.2"/>
    <circle cx="17" cy="15" r="1"   fill="#8facc8" opacity="0.6"/>
    <!-- Aletas -->
    <path d="M11 22L6 27L11 26V22Z"  fill="#c23e12"/>
    <path d="M25 22L30 27L25 26V22Z" fill="#c23e12"/>
  </svg>
</div>

<script>
import { gsap } from 'gsap';

(function () {
  if (!window.matchMedia('(pointer: fine)').matches) return;

  var cursor = document.getElementById('rocketCursor');
  var svg    = document.getElementById('rocket-svg');
  var flame  = document.getElementById('rocket-flame');
  if (!cursor || !svg || !flame) return;

  gsap.to(cursor, { opacity: 1, duration: 0.2 });

  var mx = window.innerWidth / 2, my = window.innerHeight / 2;
  var px = mx, py = my;
  var cx = mx, cy = my;

  var THRESHOLD = 7;
  var activeP = 0, MAX_P = 18;

  var moveX = gsap.quickTo(cursor, 'x', { duration: 0.1, ease: 'power2.out' });
  var moveY = gsap.quickTo(cursor, 'y', { duration: 0.1, ease: 'power2.out' });

  window.addEventListener('mousemove', function (e) { mx = e.clientX; my = e.clientY; });

  // Delegación de eventos para aplicar la clase .hot al cursor en elementos interactivos
  document.body.addEventListener('mouseover', function (e) {
    var target = e.target as HTMLElement | null;
    if (!target) return;
    var interactive = target.closest('a, button, input, select, textarea, .srow, .proj, .gal-pill, .sn-pill, .bc, .gal-item, .otro-card, .btn-line, .btn-fill, [role="button"]');
    if (interactive) {
      cursor!.classList.add('hot');
    }
  });

  document.body.addEventListener('mouseout', function (e) {
    var target = e.target as HTMLElement | null;
    if (!target) return;
    var interactive = target.closest('a, button, input, select, textarea, .srow, .proj, .gal-pill, .sn-pill, .bc, .gal-item, .otro-card, .btn-line, .btn-fill, [role="button"]');
    if (interactive) {
      cursor!.classList.remove('hot');
    }
  });

  function spawn(x: number, y: number) {
    if (activeP >= MAX_P) return;
    activeP++;
    var p  = document.createElement('span');
    p.className = 'spark';
    var sz = 3 + Math.random() * 4;
    p.style.cssText =
      'width:' + sz + 'px;height:' + sz + 'px;' +
      'left:' + (x + (Math.random() - .5) * 18) + 'px;' +
      'top:'  + (y + 8 + Math.random() * 10)    + 'px;opacity:1;';
    document.body.appendChild(p);
    gsap.to(p, {
      y: 18 + Math.random() * 18,
      x: (Math.random() - .5) * 22,
      opacity: 0, scale: .15,
      duration: .4 + Math.random() * .3,
      ease: 'power1.out',
      onComplete: function () { p.remove(); activeP--; },
    });
  }

  function tick() {
    var dx  = mx - px, dy = my - py;
    var vel = Math.hypot(dx, dy);

    cx += (mx - cx) * 0.16;
    cy += (my - cy) * 0.16;

    moveX(cx - 21);
    moveY(cy - 21);

    if (vel > 0.4) {
      var angle = Math.atan2(dy, dx) * (180 / Math.PI) + 90;
      gsap.to(svg, { rotation: angle, duration: 0.14, ease: 'power1.out', transformOrigin: '50% 50%' });
    }

    var fScale = Math.min(2, Math.max(0.5, 0.5 + vel * 0.07));
    gsap.to(flame, { scaleY: fScale, duration: 0.09, ease: 'power1.out' });

    if (vel > THRESHOLD) spawn(cx, cy);

    px = mx; py = my;
    requestAnimationFrame(tick);
  }

  tick();
})();
</script>
