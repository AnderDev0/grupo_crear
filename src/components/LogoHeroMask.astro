---
import { readFileSync } from 'node:fs';
import { resolve }      from 'node:path';

let logoPaths = '';
try {
  const svgRaw  = readFileSync(resolve('public/logo-Grupo-Crear-vector_sintext.svg'), 'utf-8');
  const matches = [...svgRaw.matchAll(/<path\s+class="b"[^>]*\/>/g)];
  logoPaths = matches.map(m => m[0].replace(/\s*class="[^"]*"/g, '')).join('\n');
} catch (_) {}
---

{logoPaths && (
  <div
    id="logo-hero-overlay"
    aria-hidden="true"
    style="position:absolute;inset:0;z-index:20;pointer-events:none;opacity:0;"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      style="position:absolute;inset:0;width:100%;height:100%;display:block;overflow:hidden;"
      aria-hidden="true"
    >
      <defs>
        <mask id="logo-hero-mask">
          <rect width="100%" height="100%" fill="white"/>
          <g id="logo-hero-paths" fill="black">
            <svg
              viewBox="0 0 1199 680"
              preserveAspectRatio="xMidYMid meet"
              x="5%" y="10%"
              width="90%" height="80%"
            >
              <Fragment set:html={logoPaths} />
            </svg>
          </g>
        </mask>
      </defs>

      <foreignObject x="0" y="0" width="100%" height="100%" mask="url(#logo-hero-mask)">
        <canvas id="lightfall-canvas" style="display:block;width:100%;height:100%;"></canvas>
      </foreignObject>

      <!--
        Trazo naranja sobre la silueta del logo.
        Mismo position/viewBox que el grupo de la máscara.
        GSAP le aplica la misma animación scale 1→55 en index.astro (id: logo-stroke-group).
        filter="url(#stroke-glow)" da un leve halo para que sea visible sobre el Lightfall.
      -->
      <defs>
        <filter id="stroke-glow" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>

      <g id="logo-stroke-group">
        <svg
          viewBox="0 0 1199 680"
          preserveAspectRatio="xMidYMid meet"
          x="5%" y="10%"
          width="90%" height="80%"
        >
          <g fill="none" stroke="#E84E1B" stroke-width="1.8"
             stroke-linejoin="round" stroke-linecap="round"
             filter="url(#stroke-glow)" opacity="0.85">
            <Fragment set:html={logoPaths} />
          </g>
        </svg>
      </g>
    </svg>
  </div>
)}

<script is:inline>
  (function initLightfall() {
    const canvas = document.getElementById('lightfall-canvas');
    if (!canvas) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const isMobile = window.innerWidth < 768
      || window.matchMedia('(pointer: coarse)').matches;

    const DPR         = Math.min(window.devicePixelRatio || 1, isMobile ? 1.0 : 1.5);
    const SCENE_ITERS = isMobile ? 20 : 39;
    const MAX_STREAKS = isMobile ? 4  : 8;
    const TARGET_MS   = isMobile ? 34 : 16;

    const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
    if (!gl) return;

    // ── Shaders ────────────────────────────────────────────────────────────
    const VERT = `attribute vec2 position;
void main(){gl_Position=vec4(position,0.,1.);}`;

    const FRAG = `precision highp float;
uniform vec3  iResolution;
uniform float iTime;
uniform vec3  uColor0,uColor1,uColor2,uColor3;
uniform int   uColorCount;
uniform vec3  uBgColor;
uniform float uSpeed,uStreakWidth,uStreakLength,uGlow,uDensity,uTwinkle,uZoom,uBgGlow;
uniform int   uStreakCount;

vec3 palette(float h){
  int i=int(floor(clamp(h,0.,.999999)*float(uColorCount)));
  if(i<=0)return uColor0;
  if(i==1)return uColor1;
  if(i==2)return uColor2;
  return uColor3;
}
vec3 tanhv(vec3 x){vec3 e=exp(-2.*x);return(1.-e)/(1.+e);}

vec2 sceneC(vec2 f,vec2 r){
  vec2 P=(f+f-r)/r.x;
  float z=0.,d=1e3;
  vec4 O=vec4(0.);
  for(int k=0;k<${SCENE_ITERS};k++){
    if(d<=1e-4)break;
    O=z*normalize(vec4(P,uZoom,0.))-vec4(0.,4.,1.,0.)/4.5;
    d=1.-sqrt(length(O*O));
    z+=d;
  }
  return vec2(O.x,atan(O.z,O.y));
}

void main(){
  vec2 C=gl_FragCoord.xy,r=iResolution.xy;
  vec2 uv0=(C+C-r)/r.x;
  float T=.1*iTime*uSpeed+9.;
  float angR=max(1.,floor(6.28318*max(uDensity,.05)+.5));
  vec2 Y=vec2(5e-3,6.28318/angR);
  vec2 c0=sceneC(C,r),cdx=sceneC(C+vec2(1.,0.),r),cdy=sceneC(C+vec2(0.,1.),r);
  vec2 dCx=cdx-c0,dCy=cdy-c0;
  dCx.y-=6.28318*floor(dCx.y/6.28318+.5);
  dCy.y-=6.28318*floor(dCy.y/6.28318+.5);
  vec2 fw=abs(dCx)+abs(dCy);
  C=c0;
  vec2 P=vec2(2.,1.)*uv0-(r/r.x)*vec2(0.,1.);
  vec4 O=vec4(uBgColor*90.*uBgGlow/(1e3*dot(P,P)+6.),0.);
  float zr=5e-4*uStreakWidth;
  vec2 rr=vec2(max(length(fw),1e-5));
  float tail=19./max(uStreakLength,.05);
  for(int m=0;m<${MAX_STREAKS};m++){
    if(m>=uStreakCount)break;
    float jf=float(m)+1.;
    float ic=fract(sin(dot(vec2(jf,floor(C.x/Y.x+.5)),vec2(7.,11.))*73.));
    vec2 Pp=C-(T+T*ic)*vec2(0.,1.);
    Pp-=floor(Pp/Y+.5)*Y;
    float h=fract(8663.*ic);
    vec3 col=palette(h);
    float w=mix(1.5,1.+sin(T+7.*h+4.),uTwinkle);
    vec2 inner=vec2(length(max(Pp,vec2(-1.,0.))),length(Pp)-zr)-zr;
    vec2 sm=vec2(1.)-smoothstep(-rr,rr,inner);
    O.rgb+=dot(sm,vec2(exp(tail*Pp.y),3.))*col*w;
    C.x+=Y.x/8.;
  }
  vec3 col=sqrt(tanhv(max(O.rgb*uGlow-vec3(.04,.08,.02),0.)));
  gl_FragColor=vec4(col,1.);
}`;

    // ── Compilar shaders ────────────────────────────────────────────────────
    function mkShader(type, src) {
      const s = gl.createShader(type);
      gl.shaderSource(s, src);
      gl.compileShader(s);
      if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
        console.warn('[Lightfall]', gl.getShaderInfoLog(s));
        gl.deleteShader(s);
        return null;
      }
      return s;
    }

    const vs = mkShader(gl.VERTEX_SHADER,   VERT);
    const fs = mkShader(gl.FRAGMENT_SHADER, FRAG);
    if (!vs || !fs) return;

    const prog = gl.createProgram();
    gl.attachShader(prog, vs);
    gl.attachShader(prog, fs);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) return;
    gl.useProgram(prog);

    // Triángulo fullscreen (cubre el viewport con 3 vértices)
    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 3,-1, -1,3]), gl.STATIC_DRAW);
    const posLoc = gl.getAttribLocation(prog, 'position');
    gl.enableVertexAttribArray(posLoc);
    gl.vertexAttribPointer(posLoc, 2, gl.FLOAT, false, 0, 0);

    // ── Uniforms ────────────────────────────────────────────────────────────
    const h2rgb = (h) => {
      const c = h.replace('#','').padEnd(6,'0');
      return [parseInt(c.slice(0,2),16)/255, parseInt(c.slice(2,4),16)/255, parseInt(c.slice(4,6),16)/255];
    };
    const u = (n) => gl.getUniformLocation(prog, n);

    const U = {
      res:  u('iResolution'), time: u('iTime'),
      c0: u('uColor0'), c1: u('uColor1'), c2: u('uColor2'), c3: u('uColor3'),
      cnt: u('uColorCount'), bg: u('uBgColor'),
      spd: u('uSpeed'), sc: u('uStreakCount'),
      sw:  u('uStreakWidth'), sl: u('uStreakLength'),
      glow: u('uGlow'), den: u('uDensity'),
      twk: u('uTwinkle'), zoom: u('uZoom'), bgg: u('uBgGlow'),
    };

    // Identidad Grupo Crear: streaks naranjas sobre fondo navy
    const cols = ['#E84E1B','#FF6B35','#FF9F70','#C23E12'].map(h2rgb);
    gl.uniform3fv(U.c0, cols[0]); gl.uniform3fv(U.c1, cols[1]);
    gl.uniform3fv(U.c2, cols[2]); gl.uniform3fv(U.c3, cols[3]);
    gl.uniform1i(U.cnt,  4);
    gl.uniform3fv(U.bg,  h2rgb('#001433'));
    gl.uniform1f(U.spd,  isMobile ? 0.35 : 0.55);
    gl.uniform1i(U.sc,   isMobile ? 3    : 6);
    gl.uniform1f(U.sw,   0.9);
    gl.uniform1f(U.sl,   1.2);
    gl.uniform1f(U.glow, 1.1);
    gl.uniform1f(U.den,  0.5);
    gl.uniform1f(U.twk,  0.8);
    gl.uniform1f(U.zoom, 2.5);
    gl.uniform1f(U.bgg,  0.65);

    // ── Resize ──────────────────────────────────────────────────────────────
    function resize() {
      const parent = canvas.parentElement;
      const rect   = parent ? parent.getBoundingClientRect() : canvas.getBoundingClientRect();
      const w = Math.round((rect.width  || window.innerWidth)  * DPR);
      const h = Math.round((rect.height || window.innerHeight) * DPR);
      if (canvas.width !== w || canvas.height !== h) {
        canvas.width  = w;
        canvas.height = h;
        gl.viewport(0, 0, w, h);
      }
      gl.uniform3fv(U.res, [w, h, 1]);
    }

    const ro = new ResizeObserver(resize);
    ro.observe(canvas.parentElement);
    resize();

    // ── Render loop ─────────────────────────────────────────────────────────
    let raf   = -1;
    let alive = true;
    let lastT = 0;

    function stop() {
      alive = false;
      cancelAnimationFrame(raf);
      ro.disconnect();
      const ext = gl.getExtension('WEBGL_lose_context');
      if (ext) ext.loseContext();
    }

    function loop(t) {
      if (!alive) return;
      raf = requestAnimationFrame(loop);
      if (t - lastT < TARGET_MS) return;
      lastT = t;
      gl.uniform1f(U.time, t * 0.001);
      gl.drawArrays(gl.TRIANGLES, 0, 3);
    }
    raf = requestAnimationFrame(loop);

    // Libera GPU cuando el overlay se oculta (tras completar el scroll)
    const overlay = document.getElementById('logo-hero-overlay');
    if (overlay) {
      new MutationObserver((_, obs) => {
        if (overlay.style.display === 'none') {
          obs.disconnect();
          stop();
        }
      }).observe(overlay, { attributes: true, attributeFilter: ['style'] });
    }
  })();
</script>
