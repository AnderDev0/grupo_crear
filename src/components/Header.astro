---
import LogoDisplace from './LogoDisplace.astro';
---

<!-- aria-label distingue este nav de posibles footers/breadcrumbs en la misma página -->
<nav
  id="nav"
  aria-label="Navegación principal"
  class="fixed top-0 left-0 right-0 z-[300] h-[84px] flex items-center justify-between px-6 md:px-16 transition-all duration-500 ease-out border-b border-transparent"
>
  <LogoDisplace />

  <!-- role="list" explícito: Tailwind list-none elimina el rol semántico en VoiceOver/Safari -->
  <ul class="menu hidden md:flex items-center gap-8 md:gap-11 list-none" id="menu" role="list">
    <li><a href="#serv" class="text-white/60 hover:text-white text-sm font-medium tracking-wide transition-colors duration-300 relative py-1 after:content-[''] after:absolute after:left-0 after:bottom-[-6px] after:w-0 after:h-[1.5px] after:bg-[#E84E1B] after:transition-all after:duration-350 hover:after:w-full">Servicios</a></li>
    <li><a href="#nos"  class="text-white/60 hover:text-white text-sm font-medium tracking-wide transition-colors duration-300 relative py-1 after:content-[''] after:absolute after:left-0 after:bottom-[-6px] after:w-0 after:h-[1.5px] after:bg-[#E84E1B] after:transition-all after:duration-350 hover:after:w-full">Estudio</a></li>
    <li><a href="#port" class="text-white/60 hover:text-white text-sm font-medium tracking-wide transition-colors duration-300 relative py-1 after:content-[''] after:absolute after:left-0 after:bottom-[-6px] after:w-0 after:h-[1.5px] after:bg-[#E84E1B] after:transition-all after:duration-350 hover:after:w-full">Trabajo</a></li>
    <li>
      <a href="#cto" class="cta inline-flex items-center gap-2 bg-[#E84E1B] hover:bg-[#c23e12] text-white px-5 py-2.5 rounded-full font-semibold text-sm transition-all duration-300 group">
        Cotizar
        <!-- aria-hidden: decorativo, el texto del enlace ya provee el nombre accesible -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 transition-transform duration-350 ease-out group-hover:translate-x-1" aria-hidden="true" focusable="false">
          <path d="M5 12h14M13 6l6 6-6 6"/>
        </svg>
      </a>
    </li>
  </ul>

  <!--
    w-12 h-12 = 48×48 px (WCAG 2.5.5 touch target mínimo 44px, Google recomienda 48px).
    aria-expanded comunica el estado abierto/cerrado a lectores de pantalla.
    aria-controls vincula el botón con el menú que controla.
  -->
  <button
    class="burger flex md:hidden w-12 h-12 border border-white/12 rounded-full bg-transparent flex-col items-center justify-center gap-1.5"
    id="burger"
    type="button"
    aria-label="Menú"
    aria-expanded="false"
    aria-controls="menu"
  >
    <span class="w-[18px] h-[1.5px] bg-white transition-all duration-300" aria-hidden="true"></span>
    <span class="w-[18px] h-[1.5px] bg-white transition-all duration-300" aria-hidden="true"></span>
    <span class="w-[18px] h-[1.5px] bg-white transition-all duration-300" aria-hidden="true"></span>
  </button>
</nav>

<script>
  const nav    = document.getElementById('nav');
  const burger = document.getElementById('burger');
  const menu   = document.getElementById('menu');

  window.addEventListener('scroll', () => {
    if (!nav) return;
    if (window.scrollY > 50) {
      nav.classList.add('h-[64px]', 'bg-[#00102a]/72', 'backdrop-blur-[24px]', 'border-white/6');
      nav.classList.remove('h-[84px]', 'border-transparent');
    } else {
      nav.classList.add('h-[84px]', 'border-transparent');
      nav.classList.remove('h-[64px]', 'bg-[#00102a]/72', 'backdrop-blur-[24px]', 'border-white/6');
    }
  }, { passive: true });

  if (burger && menu) {
    function openMenu() {
      menu.classList.remove('hidden');
      menu.classList.add('flex', 'flex-col', 'absolute', 'top-[64px]', 'left-0', 'right-0',
        'bg-[#00102a]/97', 'backdrop-blur-[20px]', 'p-7', 'border-b', 'border-white/6');
      // Comunica estado abierto a lectores de pantalla
      burger.setAttribute('aria-expanded', 'true');
    }

    function closeMenu() {
      menu.classList.add('hidden');
      menu.classList.remove('flex', 'flex-col', 'absolute', 'top-[64px]', 'left-0', 'right-0',
        'bg-[#00102a]/97', 'backdrop-blur-[20px]', 'p-7', 'border-b', 'border-white/6');
      // Comunica estado cerrado a lectores de pantalla
      burger.setAttribute('aria-expanded', 'false');
    }

    burger.addEventListener('click', () => {
      const isOpen = burger.getAttribute('aria-expanded') === 'true';
      isOpen ? closeMenu() : openMenu();
    });

    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', closeMenu);
    });
  }
</script>
